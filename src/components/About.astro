---
import { Image } from 'astro:assets';
import doctorPhoto from '../assets/images/doctor-photo.png';
import { readFileSync } from 'node:fs';
import path from 'node:path';

const doodlesDir = path.join(process.cwd(), 'public/doodles');
const arrow1 = readFileSync(path.join(doodlesDir, 'arrow-1.svg'), 'utf-8');
const arrow2 = readFileSync(path.join(doodlesDir, 'arrow-2.svg'), 'utf-8');
const arrow3 = readFileSync(path.join(doodlesDir, 'arrow-3.svg'), 'utf-8');
const arrow4 = readFileSync(path.join(doodlesDir, 'arrow-4.svg'), 'utf-8');
const arrow5 = readFileSync(path.join(doodlesDir, 'arrow-5.svg'), 'utf-8');
const arrow6 = readFileSync(path.join(doodlesDir, 'arrow-6.svg'), 'utf-8');

const pills = [
  { text: "Fellow RSPH", style: "yellow", ellipse: "elipse-1", top: "18.4%", left: "49.7%", rotate: "9.91deg", tx: "0", extraClass: "about__pill--rsph" },
  { text: "hosts a podcast", style: "plain", top: "26%", left: "56.3%", tx: "0" },
  { text: "makes sex ed \nsafe since 2019", style: "plain", top: "13%", left: "73.5%", rotate: "3deg", tx: "-50%", extraStyle: "text-align:center;white-space:pre-line;" },
  { text: "award-winning\n creator", style: "plain", top: "26.3%", left: "78.4%", tx: "-100%" },
  { text: "answered the internet's questions\n(in a whole book)", style: "plain", top: "36.1%", left: "36%", tx: "-100%" },
  { text: "Oxford-trained", style: "purple", ellipse: "elipse-3", top: "44.6%", left: "80.3%", rotate: "7.36deg", tx: "0" },
  { text: "Doctor", style: "purple-200", ellipse: "elipse-2", top: "57.4%", left: "42.1%", rotate: "-7.58deg", tx: "0" },
  { text: "writes a column", style: "plain", top: "55.2%", left: "81.6%", rotate: "5deg", tx: "0" },
  { text: "NITI Aayog\n recognized\nhealth educator", style: "plain", top: "74.4%", left: "42%", tx: "-100%" },
  { text: "Bestselling\nAuthor", style: "yellow", ellipse: "elipse-4", top: "77.3%", left: "80.1%", rotate: "2deg", tx: "0" },
];
---

<section class="about" id="about">
  <div class="about__left">
    <p class="about__meet">Hey, I'm</p>
    <p class="about__heyi">Hey, I'm</p>
    <div class="about__name-block">
      <h1 class="about__name">
        <span class="about__name-first">Doctor</span>
        <span class="about__name-tanaya">Tanaya</span>
        <span class="about__name-narendra">Narendra</span>
      </h1>
      <p class="about__aka">
        popularly known as<br />
        <strong class="about__drcuterus">
          <span class="about__drcuterus-highlight"></span>
          Dr. Cuterus
        </strong>
      </p>
    </div>
    <p class="about__bio">Bodies are fascinating. And talking about them? Completely normal. That's exactly what I'm here for. To lead with 100% science and 0% hesitation, and of course, fun!</p>
    <div class="about__ctas">
      <a href="https://mail.google.com/mail/?view=cm&to=drcuterus@gmail.com" target="_blank" rel="noopener" class="btn-primary about__btn">Work With Me</a>
      <a href="#" class="btn-outline about__btn">Book appointment</a>
    </div>
  </div>

  <div class="about__right">
    <div class="about__photo-wrap">
      <Image
        src={doctorPhoto}
        alt="Dr. Tanaya Narendra — Dr. Cuterus"
        class="about__photo"
        widths={[450, 650, 950]}
        sizes="(max-width: 768px) 80vw, 45vw"
        loading="eager"
        fetchpriority="high"
      />
    </div>
  </div>

  <!-- Overlay spans the full section — positions are % of the full 1280×832 canvas -->
  <div class="about__pills-overlay" aria-hidden="true">
    {pills.map((pill) => (
      <span
        class={`about__pill about__pill--${pill.style}${pill.extraClass ? ` ${pill.extraClass}` : ''}`}
        style={`top:${pill.top};left:${pill.left};--rotate:${pill.rotate};--tx:${pill.tx};${pill.extraStyle ?? ''}`}
      >
        {pill.ellipse && <img src={`/doodles/${pill.ellipse}.svg`} class="about__pill-ellipse" alt="" />}
        {pill.ellipse && <img src={`/doodles/${pill.ellipse.replace('elipse-', 'elipse-outline-')}.svg`} class="about__pill-ellipse-outline" alt="" />}
        {pill.text}
      </span>
    ))}

    <span class="about__arrow about__arrow--1" aria-hidden="true" set:html={arrow1} />
    <span class="about__arrow about__arrow--2" aria-hidden="true" set:html={arrow2} />
    <span class="about__arrow about__arrow--3" aria-hidden="true" set:html={arrow3} />
    <span class="about__arrow about__arrow--4" aria-hidden="true" set:html={arrow4} />
    <span class="about__arrow about__arrow--5" aria-hidden="true" set:html={arrow5} />
    <span class="about__arrow about__arrow--6" aria-hidden="true" set:html={arrow6} />
  </div>

  <div class="about__tags-mobile" aria-label="About Dr. Cuterus">
    {pills.map((pill) => (
      <span class={`about__tag-mobile about__tag-mobile--${pill.style.replace('-small', '')}`}>
        {pill.text.replace("\n", " ")}
      </span>
    ))}
  </div>

  <div class="about__pills-mobile" aria-hidden="true">

    <!-- CIRCLES -->
    <span class="about__pill about__pill--yellow about__pill--embryologist" style="top:54%;left:12%;--rotate:9.91deg;">
      <img src="/doodles/elipse-1.svg" class="about__pill-ellipse" alt="" />
      <img src="/doodles/elipse-outline-1.svg" class="about__pill-ellipse-outline" alt="" />
      embryologist
    </span>

    <span class="about__pill about__pill--purple about__pill--oxford" style="top:70%;left:0%;--rotate:7.36deg;">
      <img src="/doodles/elipse-3.svg" class="about__pill-ellipse" alt="" />
      <img src="/doodles/elipse-outline-3.svg" class="about__pill-ellipse-outline" alt="" />
      Oxford-trained
    </span>

    <span class="about__pill about__pill--yellow about__pill--bestseller" style="top:78%;left:68%;--rotate:-5deg;">
      <img src="/doodles/elipse-4.svg" class="about__pill-ellipse" alt="" />
      <img src="/doodles/elipse-outline-4.svg" class="about__pill-ellipse-outline" alt="" />
      Best-Selling<br />Author
    </span>

    <!-- PLAIN TEXT (with arrows) -->
    <span class="about__pill about__pill--plain" style="top:62%;left:3%;">hosts a podcast</span>
    <span class="about__pill about__pill--plain about__pill--sexed" style="top:46.5%;left:31%;text-align:center;">makes sex ed<br />safe since 2019</span>
    <span class="about__pill about__pill--plain" style="top:52%;right:2%;left:auto;--tx:0;text-align:right;">award-winning<br />creator</span>

    <!-- ARROWS -->
    <span class="about__arrow about__arrow--m1" aria-hidden="true" set:html={arrow5} />
    <span class="about__arrow about__arrow--m2" aria-hidden="true" set:html={arrow2} />
    <span class="about__arrow about__arrow--m3" aria-hidden="true" set:html={arrow1} />
  </div>
</section>

<style>
  .about {
    min-height: 100svh;
    padding-top: 80px;
    background-color: var(--color-beige-500);
    display: grid;
    grid-template-columns: 1fr 1fr;
    position: relative;
    overflow: hidden;
  }

  /* LEFT */
  .about__left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-start;
    padding: 10px clamp(30px, 4.7vw, 70px) 40px clamp(30px, 4.7vw, 70px);
    z-index: 2;
  }

  .about__name-block {
    display: flex;
    flex-direction: column;
    width: fit-content;
  }

  .about__meet {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: clamp(1.5rem, 2.1vw, 1.9rem);
    color: var(--color-brand-900);
    margin: 0 0 0 0;
  }

  .about__name {
    display: flex;
    flex-direction: column;
    margin: 0 0 8px 0;
    line-height: 0.78;
    gap: 0;
  }

  .about__name-first {
    font-family: var(--font-display);
    font-weight: 700;
    font-style: italic;
    font-size: clamp(2.5rem, 5.6vw, 4rem);
    color: var(--color-black);
  }

  .about__name-tanaya,
  .about__name-narendra {
    font-family: var(--font-display);
    font-weight: 700;
    font-style: italic;
    font-size: clamp(2.5rem, 5.6vw, 4rem);
    color: var(--color-brand-400);
  }

  .about__aka {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: clamp(1.5rem, 2.1vw, 1.9rem);
    color: var(--color-brand-900);
    margin: 0 0 28px 0;
    line-height: 1.0;
    text-align: right;
  }

  .about__drcuterus {
    font-weight: 700;
    color: var(--color-brand-900);
    position: relative;
    display: inline-block;
  }

  .about__drcuterus-highlight {
    position: absolute;
    inset: 0;
    background-color: var(--color-yellow-400);
    z-index: -1;
  }

  .about__bio {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: clamp(0.95rem, 1.5vw, 1.25rem);
    color: var(--color-brand-900);
    line-height: 1.5;
    margin: 0 0 32px 0;
    max-width: clamp(260px, 28vw, 420px);
  }

  .about__ctas {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .about__btn {
    font-size: clamp(1rem, 1.3vw, 1.4rem);
    padding: 12px clamp(16px, 2vw, 28px);
  }

  /* RIGHT */
  .about__right {
    position: relative;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    padding-left: clamp(20px, 3vw, 60px);
    padding-right: clamp(20px, 3vw, 60px);
    z-index: 2;
  }

  .about__photo-wrap {
    position: relative;
    width: min(420px, 90%);
  }

  .about__photo {
    width: 100%;
    height: auto;
    display: block;
  }

  /* PILLS OVERLAY — capped at design canvas height, pinned to bottom */
  .about__pills-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 720px;
    z-index: 3;
    pointer-events: none;
  }

  .about__pill {
    position: absolute;
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: clamp(1.25rem, calc(1.2vw + 0.5rem), 1.75rem);
    color: var(--color-brand-900);
    letter-spacing: -0.03em;
    white-space: pre;
    transform: translateX(var(--tx, 0)) rotate(var(--rotate, 0deg));
    padding: 6px 18px;
    line-height: 1.25;
    text-align: center;
    isolation: isolate;
  }

  .about__pill-ellipse {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 160%;
    height: 200%;
    pointer-events: none;
    z-index: -1;
  }

  .about__pill-ellipse-outline {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 185%;
    height: 185%;
    pointer-events: none;
    z-index: -1;
  }

  .about__pill--rsph .about__pill-ellipse {
    transform: translate(-50%, -50%) scaleY(1.4);
  }

  .about__pill--rsph .about__pill-ellipse-outline {
    transform: translate(-50%, -50%) scaleY(1.4);
  }

  .about__pill--plain {
    background: none;
  }

  .about__pill--plain-small {
    background: none;
    font-size: clamp(0.9rem, calc(0.95vw + 0.25rem), 1.25rem);
  }

  .about__arrow {
    position: absolute;
    opacity: 0.75;
    display: block;
  }

  .about__arrow svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* width + height set to match natural viewBox ratio so no stretching occurs */
  .about__arrow--1 {
    top: 60.8%;
    left: 82%;
    transform: rotate(90deg) scaleY(-1);
    width: 60px;
    height: 62px;
  }

  .about__arrow--2 {
    top: 24.4%;
    left: 72.4%;
    transform: rotate(-8.19deg);
    width: 23px;
    height: 65px;
  }

  .about__arrow--3 {
    top: 30.7%;
    left: 61.9%;
    transform: rotate(180deg) scaleY(-1);
    width: 29px;
    height: 41px;
  }

  .about__arrow--4 {
    top: 36.2%;
    left: 79.6%;
    width: 90px;
    height: 29px;
  }

  .about__arrow--5 {
    top: 68.4%;
    left: 48.8%;
    width: 45px;
    height: 29px;
  }

  /* arrow pointing from photo outward toward "authored a book" label */
  .about__arrow--6 {
    top: 45%;
    left: 48%;
    width: 89px;
    height: 81px;
    transform: rotate(0deg) scaleX(1);
  }

  /* Mobile-only intro text */
  .about__heyi {
    display: none;
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 1.75rem;
    color: var(--color-brand-900);
    margin: 0 0 4px 0;
    text-align: center;
  }

  /* Mobile pills overlay */
  .about__pills-mobile {
    display: none;
  }

  /* Mobile arrow positions (only used when pills-mobile is visible) */
  .about__arrow--m1 {
    top: 45%;
    left: 52%;
    transform: rotate(210deg) scaleX(-1);
    width: 40px;
    height: 100px;
  }

  .about__arrow--m2 {
    top: 64%;
    left: 22%;
    transform: rotate(-90deg);
    width: 23px;
    height: 65px;
  }

  .about__arrow--m3 {
    top: 54%;
    left: 86%;
    transform: rotate(90deg) scaleY(-1);
    width: 46px;
    height: 130px;
  }

  /* Taller ellipse for two-line "Best-Selling Author" pill */
  .about__pill--bestseller .about__pill-ellipse {
    height: 280%;
  }
  .about__pill--bestseller .about__pill-ellipse-outline {
    height: 260%;
  }

  /* Mobile tags */
  .about__tags-mobile {
    display: none;
  }

  /* RIGHT-SIDE GROUP SCALE: photo + pills/doodles scale as one unit from bottom-right */
  @media (min-width: 769px) {
    .about__right,
    .about__pills-overlay {
      transform: scale(var(--canvas-scale, 1));
      transform-origin: bottom right;
      will-change: transform;
    }
  }

  /* TABLET (769–1024px) */
  @media (max-width: 1024px) and (min-width: 769px) {
    .about__right {
      padding-left: 24px;
      padding-right: 24px;
    }

    .about__photo-wrap {
      width: min(340px, 90%);
    }
  }

  /* SHORT DESKTOP — compress vertical spacing so content fits without scrolling */
  @media (max-height: 700px) and (min-width: 769px) {
    .about__left {
      justify-content: flex-start;
    }

    .about__name {
      margin: 0 0 4px 0;
    }

    .about__aka {
      margin: 0 0 14px 0;
    }

    .about__bio {
      margin: 0 0 18px 0;
    }

    .about__ctas {
      flex-direction: row;
      flex-wrap: wrap;
    }
  }

  /* TALL DESKTOP — center left content, let top space breathe */
  @media (min-height: 800px) and (min-width: 769px) {
    .about__left {
      justify-content: center;
    }
  }

  /* MOBILE */
  @media (max-width: 768px) {
    .about {
      display: flex;
      flex-direction: column;
      height: 100svh;
      min-height: unset;
      overflow: hidden;
      padding-top: 80px;
    }

    .about__left {
      flex: 0 0 auto;
      padding: 12px 20px 8px;
      align-items: center;
      text-align: center;
    }

    .about__meet {
      display: none;
    }

    .about__bio {
      display: none;
    }

    .about__heyi {
      display: block;
      font-size: clamp(1.2rem, 4vw, 1.4rem);
      text-align: center;
      margin-bottom: 2px;
    }

    .about__name {
      align-items: center;
    }

    .about__name-first,
    .about__name-tanaya,
    .about__name-narendra {
      font-size: clamp(2.5rem, 9vw, 3rem);
    }

    .about__aka {
      font-size: clamp(1.1rem, 4.2vw, 1.6rem);
      text-align: center;
      margin-bottom: 24px;
    }

    .about__ctas {
      flex-direction: row;
      justify-content: center;
      gap: 8px;
    }

    .about__btn {
      font-size: clamp(0.9rem, 3.5vw, 1rem);
      padding: 6px 12px;
    }

    .about__right {
      flex: 1;
      min-height: 0;
      order: 0;
      padding: 0;
      justify-content: center;
      align-items: flex-end;
      overflow: hidden;
    }

    .about__photo-wrap {
      width: min(310px, 80vw);
      height: 100%;
      margin: 0 auto;
      display: flex;
      align-items: flex-end;
    }

    .about__photo {
      width: 100%;
      height: 100%;
      object-fit: contain;
      object-position: bottom center;
    }

    .about__pills-overlay {
      display: none;
    }

    .about__tags-mobile {
      display: none;
    }

    .about__pills-mobile {
      display: block;
      position: absolute;
      inset: 0;
      z-index: 3;
      pointer-events: none;
    }

    .about__pills-mobile .about__pill {
      font-size: 1rem;
    }

    .about__pills-mobile .about__pill--embryologist {
      padding-top: 2px;
      padding-bottom: 14px;
    }

    .about__pills-mobile .about__pill--oxford {
      padding-top: 1px;
      padding-bottom: 15px;
    }

    .about__pills-mobile .about__pill--embryologist .about__pill-ellipse,
    .about__pills-mobile .about__pill--embryologist .about__pill-ellipse-outline {
      transform: translate(-50%, -50%) rotate(-13deg);
    }

    .about__pills-mobile .about__pill--bestseller .about__pill-ellipse {
      top: 65%;
    }

    .about__pills-mobile .about__pill--bestseller .about__pill-ellipse-outline {
      top: 65%;
    }
  }
</style>

<script>
  function updateAboutScale(): void {
    const section = document.querySelector<HTMLElement>('.about');
    if (!section || window.innerWidth <= 768) return;
    const available = window.innerHeight - 80;
    // Scale to fill available height; cap at 1.3x to avoid pills/text growing too large
    const scale = Math.min(Math.max(available / 820, 0.7), 1.3);
    section.style.setProperty('--canvas-scale', String(scale));
  }
  updateAboutScale();
  window.addEventListener('resize', updateAboutScale);

  function checkSexEdOverlap(): void {
    if (window.innerWidth > 768) return;
    const photo = document.querySelector<HTMLImageElement>('.about__photo');
    const pill = document.querySelector<HTMLElement>('.about__pill--sexed');
    const arrow = document.querySelector<HTMLElement>('.about__arrow--m1');
    if (!photo || !pill || !arrow) return;

    const elRect = photo.getBoundingClientRect();
    const naturalW = photo.naturalWidth;
    const naturalH = photo.naturalHeight;
    if (!naturalW || !naturalH) return;

    // Calculate actual rendered image bounds (object-fit: contain, object-position: bottom center)
    const scale = Math.min(elRect.width / naturalW, elRect.height / naturalH);
    const renderedW = naturalW * scale;
    const renderedH = naturalH * scale;
    const imageLeft = elRect.left + (elRect.width - renderedW) / 2;
    const imageTop = elRect.bottom - renderedH;

    const GAP = 5;
    const expanded = {
      top: imageTop - GAP,
      bottom: elRect.bottom + GAP,
      left: imageLeft - GAP,
      right: imageLeft + renderedW + GAP,
    };

    function overlaps(el: HTMLElement): boolean {
      const r = el.getBoundingClientRect();
      return !(r.bottom < expanded.top || r.top > expanded.bottom || r.right < expanded.left || r.left > expanded.right);
    }

    const hide = overlaps(pill) || overlaps(arrow);
    pill.style.visibility = hide ? 'hidden' : '';
    arrow.style.visibility = hide ? 'hidden' : '';
  }

  const aboutPhoto = document.querySelector<HTMLImageElement>('.about__photo');
  if (aboutPhoto?.complete) {
    checkSexEdOverlap();
  } else {
    aboutPhoto?.addEventListener('load', checkSexEdOverlap);
  }
  window.addEventListener('resize', checkSexEdOverlap);
</script>
