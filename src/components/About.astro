---
import mainSvg      from '../assets/images/main.svg?url';
import sareeSvg     from '../assets/images/saree.svg?url';
import biilboardSvg from '../assets/images/biilboard.svg?url';
import doctorSvg    from '../assets/images/doctor.svg?url';
import podcastSvg   from '../assets/images/podcast.svg?url';
import divingSvg    from '../assets/images/diving.svg?url';

const logos = [
  { src: '/logos/forbes.svg',         alt: 'Forbes India'                        },
  { src: '/logos/who.svg',             alt: 'World Health Organization'           },
  { src: '/logos/delhi.svg',           alt: 'Government of Delhi',     sq: true   },
  { src: '/logos/natgeo.svg',          alt: 'National Geographic'                 },
  { src: '/logos/gates.svg',           alt: 'Gates Foundation'                    },
  { src: '/logos/better_india.svg',    alt: 'The Better India',        sq: true   },
  { src: '/logos/cosmo.svg',           alt: 'Cosmopolitan India'                  },
  { src: '/logos/hindustan_times.svg', alt: 'Hindustan Times'                     },
  { src: '/logos/fii.png',             alt: 'Feminism in India',       png: true  },
  { src: '/logos/vogue.svg',           alt: 'Vogue India'                         },
  { src: '/logos/india_govt.svg',      alt: 'Ministry of Health'                  },
  { src: '/logos/umich.svg',           alt: 'University of Michigan'              },
];

---

<section class="about" id="about">

  <!-- ─── PHOTO COLLAGE ─── -->
  <img src={mainSvg}      width="494" height="625" alt="Dr. Tanaya Narendra" class="about__photo about__photo--main"      loading="eager" fetchpriority="high" />
  <img src={sareeSvg}     width="151" height="198" alt=""                    class="about__photo about__photo--saree"     loading="eager" aria-hidden="true" />
  <img src={biilboardSvg} width="201" height="231" alt=""                    class="about__photo about__photo--billboard" loading="eager" aria-hidden="true" />
  <img src={doctorSvg}    width="140" height="176" alt=""                    class="about__photo about__photo--doctor"    loading="eager" aria-hidden="true" />
  <img src={podcastSvg}   width="277" height="189" alt=""                    class="about__photo about__photo--podcast"   loading="eager" aria-hidden="true" />
  <img src={divingSvg}    width="173" height="230" alt=""                    class="about__photo about__photo--diving"    loading="eager" aria-hidden="true" />


  <!-- "India's Favourite Sex Educator" badge -->
  <div class="about__badge" aria-hidden="true">
    <span>India's Favourite</span>
    <span>Sex Educator</span>
  </div>

  <!-- Stars — scattered across the collage -->
  <img src="/doodles/star about.svg" class="about__star about__star--1" aria-hidden="true" />
  <img src="/doodles/star about.svg" class="about__star about__star--2" aria-hidden="true" />
  <img src="/doodles/star about.svg" class="about__star about__star--3" aria-hidden="true" />
  <img src="/doodles/star about.svg" class="about__star about__star--4" aria-hidden="true" />

  <!-- ─── RIGHT-SIDE TEXT ─── -->

  <!-- Highlight bar sits behind bio text -->
  <div class="about__highlight-bar" aria-hidden="true"></div>

  <!-- Headlines -->
  <p class="about__headline about__headline--1">100% Science.</p>
  <p class="about__headline about__headline--2">0% Sharam.</p>

  <!-- +Thori si bakchodi pill -->
  <div class="about__pill-wrap" aria-hidden="true">
    <div class="about__pill-bakchodi">+Thori si bakchodi</div>
  </div>

  <!-- Bio — desktop (two-paragraph, right-aligned) -->
  <div class="about__bio-wrap about__bio-desktop">
    <div class="about__bio about__bio--hinglish">
      <p class="about__bio-intro">Hey, I'm <strong>Dr Tanaya Narendra</strong>.<br/>Better known as <strong>Dr Cuterus</strong>.</p>
      <p class="about__bio-body">A doctor, author, podcast host, educator, who answers questions people are too shy to ask out loud.</p>
    </div>
    <div class="about__bio about__bio--english">
      <p class="about__bio-intro">Hey, I'm <strong>Dr Tanaya Narendra</strong>.<br/>Better known as <strong>Dr Cuterus</strong>.</p>
      <p class="about__bio-body">A doctor, author, podcast host, educator, who answers questions people are too shy to ask out loud.</p>
    </div>
  </div>

  <!-- Bio — mobile (single paragraph, shorter, centred) -->
  <p class="about__bio-mobile about__bio-mobile--hinglish">
    Hey, I'm <strong>Dr Tanaya Narendra</strong>. Better known as <strong>Dr Cuterus</strong>. A doctor, author, podcast host, educator.
  </p>
  <p class="about__bio-mobile about__bio-mobile--english">
    Hey, I'm <strong>Dr Tanaya Narendra</strong>. Better known as <strong>Dr Cuterus</strong>. A doctor, author, podcast host, educator.
  </p>

  <!-- CTA -->
  <div class="about__cta-wrap">
    <a href="https://mail.google.com/mail/?view=cm&to=drcuterus@gmail.com" target="_blank" rel="noopener" class="btn-primary about__cta">Work With Me</a>
  </div>

  <!-- Scroll indicator -->
  <div class="about__scroll">
    <span>scroll for more</span>
    <svg class="about__scroll-arrow" width="12" height="10" viewBox="0 0 12 10" fill="none" xmlns="http://www.w3.org/2000/svg">
      <polyline points="1,1 6,8 11,1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    </svg>
  </div>

  <!-- ─── YELLOW TICKER ─── -->
  <div class="about__ticker" aria-label="Featured in">
    <div class="about__ticker-track">
      {logos.map(l => (
        <img
          src={l.src}
          alt={l.alt}
          class={`about__ticker-logo${l.sq  ? ' about__ticker-logo--sq'  : ''}${l.png ? ' about__ticker-logo--png' : ''}`}
        />
      ))}
      {logos.map(l => (
        <img
          src={l.src}
          alt=""
          class={`about__ticker-logo${l.sq  ? ' about__ticker-logo--sq'  : ''}${l.png ? ' about__ticker-logo--png' : ''}`}
        />
      ))}
    </div>
  </div>

</section>

<style>
  /* ─────────────────────────────────────────────
     SECTION
  ───────────────────────────────────────────── */
  .about {
    position: relative;
    height: 100svh;
    min-height: 560px;
    overflow: hidden;
    background-color: var(--color-beige-500);
  }

  /* ─────────────────────────────────────────────
     PHOTOS  (desktop — reference canvas 1280×832)
     left = center_x - width/2 (so element centres
     match Figma % positions after rotation)
  ───────────────────────────────────────────── */
  .about__photo {
    position: absolute;
    display: block;
    height: auto;
    z-index: 2;
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
  }

  /* main polaroid — large centre piece */
  .about__photo--main {
    width: 33%;
    max-width: 450px;
    left: 18.29%;   /* centre ~34.79% */
    top: 14.48%;
    transform: rotate(-1.87deg);
    transform-origin: center center;
    z-index: 2;
  }

  /* saree — small, top-left */
  .about__photo--saree {
    width: 10.61%;
    max-width: 140px;
    left: 7.31%;    /* centre 12.61% */
    top: 18.45%;
    transform: rotate(3.25deg);
    z-index: 3;
  }

  /* billboard — tilted, mid-left */
  .about__photo--billboard {
    width: 15.59%;
    max-width: 205px;
    left: 4.7%;    /* centre 9.12% */
    top: 39.23%;
    transform: rotate(15.88deg);
    z-index: 1;
  }

  /* doctor — bottom-left */
  .about__photo--doctor {
    width: 12.82%;
    max-width: 168px;
    left: 12.2%;    /* centre 16.61% */
    top: 65.02%;
    transform: rotate(9.68deg);
    z-index: 3;
  }

  /* podcast — landscape, lower-right of collage */
  .about__photo--podcast {
    width: 19.73%;
    max-width: 258px;
    left: 49.79%;   /* centre 59.66% */
    top: 56.12%;
    transform: rotate(8.09deg);
    z-index: 3;
  }

  /* diving — upper-right of collage */
  .about__photo--diving {
    width: 12.46%;
    max-width: 165px;
    left: 49.42%;   /* centre 55.65% */
    top: 28.44%;
    transform: rotate(-2.18deg);
    z-index: 1;
  }

  /* ─────────────────────────────────────────────
     PHOTO LABELS
  ───────────────────────────────────────────── */
  .about__img-label {
    position: absolute;
    font-family: var(--font-sans);
    font-weight: 400;
    color: var(--color-brand-900);
    font-size: clamp(10px, 1.36vw, 17px);
    margin: 0;
    z-index: 6;
    white-space: nowrap;
    line-height: 1;
  }

  .about__img-label--rtfrb {
    left: 21.19%;
    top: 12.77%;
    transform: rotate(-2deg);
  }

  .about__img-label--btc {
    left: 53.95%;
    top: 75.58%;
    transform: rotate(15deg);
  }

  /* ─────────────────────────────────────────────
     "INDIA'S FAVOURITE SEX EDUCATOR" BADGE
  ───────────────────────────────────────────── */
  .about__badge {
    position: absolute;
    left: 28.55%;
    top: 70.27%;
    background: var(--color-brand-100);
    padding: 4px 8px;
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: clamp(16px, 2.72vw, 28px);
    color: var(--color-brand-900);
    display: flex;
    flex-direction: column;
    align-items: center;
    line-height: 0.88;
    z-index: 5;
    white-space: nowrap;
  }

  /* ─────────────────────────────────────────────
     STAR DECORATIONS
  ───────────────────────────────────────────── */
  .about__star {
    position: absolute;
    display: block;
    height: auto;
    pointer-events: none;
    z-index: 4;
  }

  /* top-left, above/left of saree photo */
  .about__star--1 { width: 60px; left: 15.03%;  top: 15.7%; }
  /* right side of collage, between main and diving photo */
  .about__star--2 { width: 50px; left: 47.0%;  top: 28.0%; }
  /* lower-left, below billboard photo */
  .about__star--3 { display: none; }
  /* lower-center, between doctor and podcast */
  .about__star--4 { width: 64px; left: 47.5%;  top: 61.2%; }

  /* ─────────────────────────────────────────────
     HEADLINES
  ───────────────────────────────────────────── */
  .about__headline {
    position: absolute;
    margin: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    color: var(--color-brand-400);
    font-size: clamp(32px, 5vw, 64px);
    line-height: 1.25;
    letter-spacing: -0.03em;
    white-space: nowrap;
    z-index: 5;
    text-align: right;
  }

  /* Right-anchored so text never clips — staggered inset matches Figma rhythm */
  .about__headline--1 {
    right: 4.69%;   /* ≈ 60px on 1280px canvas */
    top: 19.47%;
  }
  .about__headline--2 {
    right: 3.28%;   /* ≈ 42px — slightly tighter, matches Figma offset */
    top: 25.6%;
  }

  /* ─────────────────────────────────────────────
     +THORI SI BAKCHODI PILL
  ───────────────────────────────────────────── */
  .about__pill-wrap {
    position: absolute;
    left: 80.13%;
    top: 33.85%;
    transform: rotate(-5.99deg);
  }
  .about__pill-bakchodi {
    background: var(--color-yellow-500);
    border-radius: 999px;
    padding: 8px 16px;
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: clamp(14px, 1.875vw, 24px);
    color: var(--color-black);
    white-space: nowrap;
    line-height: 1.3;
  }

  /* ─────────────────────────────────────────────
     BIO TEXT
  ───────────────────────────────────────────── */
  .about__bio-wrap {
    position: absolute;
    right: 60px;
    left: auto;
    top: 42.55%;
    width: 25%;
    z-index: 5;
  }

  .about__bio {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: clamp(13px, 1.875vw, 20px);
    color: var(--color-brand-900);
    text-align: right;
    margin: 0;
  }

  .about__bio-intro {
    margin: 0;
    line-height: 1.15;
  }

  .about__bio-body {
    margin: 0.8em 0 0;
    line-height: 1.2;
  }

  .about__bio--english { display: none; }
  :global([data-lang="english"]) .about__bio--english  { display: block; }
  :global([data-lang="english"]) .about__bio--hinglish { display: none; }

  /* mobile bio — hidden on desktop */
  .about__bio-mobile { display: none; }

  /* ─────────────────────────────────────────────
     CTA BUTTON
  ───────────────────────────────────────────── */
  .about__cta-wrap {
    position: absolute;
    right: 60px;
    left: auto;
    top: 67.07%;
    z-index: 5;
  }

  .about__cta {
    font-size: clamp(14px, 1.875vw, 24px);
    padding: clamp(8px, 0.95vh, 12px) clamp(14px, 1.4vw, 18px);
  }

  /* ─────────────────────────────────────────────
     SCROLL INDICATOR
  ───────────────────────────────────────────── */
  .about__scroll {
    position: absolute;
    right: 60px;
    left: auto;
    top: 85.21%;
    z-index: 5;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid var(--color-brand-400);
    border-radius: 100px;
    padding: 4px 12px;
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: clamp(11px, 1.4vw, 18px);
    color: var(--color-brand-900);
    white-space: nowrap;
    cursor: default;
  }

  .about__scroll-arrow {
    flex-shrink: 0;
    color: var(--color-brand-900);
  }

  /* ─────────────────────────────────────────────
     YELLOW TICKER
  ───────────────────────────────────────────── */
  .about__ticker {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 60px;
    background-color: var(--color-yellow-500);
    overflow: hidden;
    z-index: 10;
  }

  @keyframes about-ticker {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .about__ticker-track {
    display: flex;
    align-items: center;
    gap: 64px;
    width: max-content;
    height: 100%;
    animation: about-ticker 50s linear infinite;
    animation-play-state: paused;
    will-change: transform;
    padding: 0 32px;
  }

  .about__ticker-track.ticker-ready {
    animation-play-state: running;
  }

  .about__ticker-logo {
    height: 30px;
    width: auto;
    flex-shrink: 0;
    display: block;
    object-fit: contain;
    filter: brightness(0);
  }
  .about__ticker-logo--sq  { height: 38px; }
  .about__ticker-logo--png { filter: grayscale(1) contrast(10); mix-blend-mode: multiply; }


  /* ─────────────────────────────────────────────
     TABLET  (769 – 1024 px)
     Slightly scale down the collage and text
  ───────────────────────────────────────────── */
  @media (max-width: 1024px) and (min-width: 769px) {
    .about__badge { font-size: clamp(14px, 2.2vw, 28px); }
  }

  /* ─────────────────────────────────────────────
     MOBILE  (≤ 768 px)
     Reference canvas: 402 × 832 px
     Photos in top ~45 %, text in bottom ~45 %
  ───────────────────────────────────────────── */
  @media (max-width: 768px) {

    /* ── photos — exact Figma mobile positions (402×832 canvas) ── */

    /* main: centre 47.6%, width 60% (Figma: 240px / 402px canvas) */
    .about__photo--main {
      width: 60%;
      left: 17.7%;
      top: calc(10.25% + 20px);
    }

    /* saree: top-left, overlaps main left edge */
    .about__photo--saree {
      width: 21.3%;
      left: 3.2%;
      top: calc(11.24% + 20px);
    }

    /* billboard: intentionally bleeds off the left edge (Figma: -4.5%) */
    .about__photo--billboard {
      width: 28.6%;
      left: -4.5%;
      top: calc(23% + 20px);
    }

    /* doctor: lower-left cluster */
    .about__photo--doctor {
      width: 19.9%;
      left: 8.7%;
      top: calc(36.9% + 20px);
    }

    /* podcast: intentionally bleeds off the right edge (Figma: ~104% total) */
    .about__photo--podcast {
      width: 39.6%;
      left: 64.7%;
      top: calc(32.4% + 20px);
    }

    /* diving: upper-right, outside main photo bounds so clearly visible */
    .about__photo--diving {
      width: 24.4%;
      left: 70.2%;
      top: calc(15.9% + 20px);
    }

    /* ── photo labels ── */
    .about__img-label { font-size: 12px; }
    .about__img-label--rtfrb { left: 25%; top: calc(8.33% + 20px); }
    .about__img-label--btc   { left: 64%; top: calc(44% + 20px);   }

    /* ── badge ── */
    /* top = photo_top + 82% of photo_height
       photo_height = 60vw × (625/494) = 75.9vw → 82% = 62vw
       vw-based so badge stays on the photo on all phone heights */
    .about__badge {
      left: 47.5%;
      top: calc(10.25% + 20px + 62vw);
      transform: translateX(-50%);
      font-size: 16px;
    }

    /* ── stars: Figma mobile positions ── */
    .about__star--1 { width: 32px; left: 13.9%; top: calc(9.38% + 20px); }
    .about__star--2 { width: 36px; left: 65.2%; top: calc(29.39% + 20px); }
    .about__star--3 { display: block; width: 32px; left: 21.4%; top: calc(41.53% + 20px); }
    .about__star--4 { display: none; }

    /* ── highlight bar: hidden on mobile ── */
    .about__highlight-bar { display: none; }

    /* ── headlines ── */
    .about__headline {
      font-size: clamp(32px, 11.94vw, 48px);
      right: auto;
      text-align: center;
      transform: translateX(-50%);
    }
    .about__headline--1 { left: 50%; top: 51%; }
    .about__headline--2 { left: 50%; top: 57%; }

    /* ── pill ── */
    .about__pill-wrap {
      left: 50%;
      top: 63%;
      transform: translateX(-50%) rotate(-5.99deg);
    }
    .about__pill-bakchodi { font-size: clamp(16px, 5vw, 20px); }

    /* ── bio ── */
    .about__bio-desktop { display: none; }

    .about__bio-mobile {
      display: block;
      position: absolute;
      left: 50%;
      top: 70%;
      width: 79%;
      transform: translateX(-50%);
      font-family: var(--font-sans);
      font-weight: 400;
      font-size: clamp(15px, 4.98vw, 20px);
      line-height: 1.2;
      color: var(--color-brand-900);
      text-align: center;
      margin: 0;
      z-index: 5;
    }
    .about__bio-mobile--english { display: none; }
    :global([data-lang="english"]) .about__bio-mobile--english  { display: block; }
    :global([data-lang="english"]) .about__bio-mobile--hinglish { display: none; }

    /* ── CTA ── */
    .about__cta-wrap {
      left: 50%;
      top: 80%;
      transform: translateX(-50%);
    }
    .about__cta { font-size: clamp(15px, 4.5vw, 20px); }

    /* ── scroll ── */
    .about__scroll {
      display: none;
    }
  }
</style>

<script>
  const track = document.querySelector<HTMLElement>('.about__ticker-track');
  if (track) {
    const imgs = Array.from(track.querySelectorAll<HTMLImageElement>('img'));
    const total = imgs.length;
    if (total === 0) {
      track.classList.add('ticker-ready');
    } else {
      let loaded = 0;
      function onLoad() {
        loaded++;
        if (loaded >= total) track.classList.add('ticker-ready');
      }
      imgs.forEach(img => {
        if (img.complete) onLoad();
        else { img.addEventListener('load', onLoad, { once: true }); img.addEventListener('error', onLoad, { once: true }); }
      });
    }
  }
</script>
