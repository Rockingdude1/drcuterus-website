---
import { Image } from 'astro:assets';
import fursatPhoto from '../assets/images/fursat-photo.png';
import fursatLogo from '../assets/images/fursat-logo.png';
---

<section class="fursat" id="fursat">
  <div class="fursat__left">
    <h2 class="fursat__heading">Made a bra for you</h2>

    <div class="fursat__desc-wrap">
      <div class="fursat__logo-row">
        <Image src={fursatLogo} alt="Fursat" class="fursat__logo" />
      </div>
      <div class="fursat__desc-box">
        <p class="fursat__desc">
          and I proudly present <strong>FURSAT</strong>: our <strong>cloud-soft</strong>,{" "}
          <strong>medium-impact bra</strong> designed to hold you (and your bewbies) with love.
        </p>
      </div>
    </div>

    <ul class="fursat__features">
      <li class="fursat__feature">
        <img src="/doodles/fursat-bullets.svg" alt="" class="fursat__bullet" width="23" height="23" />
        Wide straps (no angry shoulders)
      </li>
      <li class="fursat__feature">
        <img src="/doodles/fursat-bullets.svg" alt="" class="fursat__bullet" width="23" height="23" />
        Dreamy colours
      </li>
      <li class="fursat__feature">
        <img src="/doodles/fursat-bullets.svg" alt="" class="fursat__bullet" width="23" height="23" />
        Sexy backs (Justin Timberlake, we're watching)
      </li>
    </ul>

    <div class="fursat__quote-box">
      <p class="fursat__quote">
        For the girl who works hard, stretches slow, cries easy, and deserves every second of fursat.
      </p>
    </div>

    <div class="fursat__cta-wrap">
      <a href="https://letstilt.com/collections/fursat-bras" target="_blank" rel="noopener" class="btn-primary fursat__cta">Order your Fursat Now</a>
      <p class="fursat__cta-sub">and your boobs will thank you.</p>
    </div>
  </div>

  <div class="fursat__right">
    <div class="fursat__photo-wrap">
      <Image src={fursatPhoto} alt="Fursat bras collection" class="fursat__photo" />
    </div>
  </div>
</section>

<style>
  .fursat {
    background-color: var(--color-beige-500);
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 100svh;
    overflow: hidden;
  }

  /* LEFT */
  .fursat__left {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 80px 40px 60px 60px;
    gap: 20px;
  }

  .fursat__desc-wrap {
    position: relative;
    width: 100%;
    max-width: 520px;
  }

  .fursat__logo-row {
    position: absolute;
    top: 0;
    left: 0;
    transform: translate(-15%, -45%);
    z-index: 2;
  }

  .fursat__logo {
    width: 68px;
    height: auto;
    transform: rotate(-10deg);
  }

  .fursat__heading {
    font-family: var(--font-display);
    font-weight: 500;
    font-style: italic;
    font-size: clamp(2rem, 3.5vw, 3rem);
    color: var(--color-brand-400);
    margin: 0;
    letter-spacing: -0.06em;
    line-height: 1;
    text-align: center;
    max-width: 520px;
  }

  .fursat__desc-box {
    background-color: var(--color-brand-100);
    padding: 12px 16px;
    max-width: 520px;
  }

  .fursat__desc {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1.1rem;
    color: var(--color-black);
    margin: 0;
    line-height: 1.5;
  }

  .fursat__features {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
    width: 100%;
    max-width: 520px;
  }

  .fursat__feature {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1.1rem;
    color: var(--color-black);
    line-height: 1.4;
  }

  .fursat__bullet {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .fursat__quote-box {
    border: 1px solid var(--color-black);
    border-radius: 100px;
    padding: 12px 24px;
    max-width: 520px;
  }

  .fursat__quote {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1.1rem;
    color: var(--color-black);
    margin: 0;
    line-height: 1.5;
  }

  .fursat__cta-wrap {
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: center;
    max-width: 520px;
  }

  .fursat__cta {
    font-size: 1rem;
  }

  .fursat__cta-sub {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-black);
    margin: 0;
  }

  /* RIGHT — single photo */
  .fursat__right {
    overflow: hidden;
    background-color: var(--color-beige-500);
    display: flex;
    align-items: center;
    justify-content: center;
    padding-top: 80px;
  }

  .fursat__photo-wrap {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .fursat__photo {
    width: 100%;
    height: 100%;
    max-height: calc(100svh - 80px);
    object-fit: contain;
    object-position: right center;
    display: block;
  }


  /* TABLET (769–1024px) */
  @media (max-width: 1024px) and (min-width: 769px) {
    .fursat__left {
      padding: 48px 24px 48px 32px;
    }

    .fursat__heading,
    .fursat__desc-box,
    .fursat__features,
    .fursat__cta-wrap {
      max-width: 90%;
    }
  }

  /* MOBILE */
  @media (max-width: 768px) {
    .fursat {
      display: flex;
      flex-direction: column;
    }

    /* Photo moves to top */
    .fursat__right {
      order: 1;
      height: 55svh;
      padding: 0;
      min-height: unset;
    }

    .fursat__photo-wrap {
      height: 100%;
    }

    .fursat__photo {
      object-fit: cover;
      object-position: center top;
    }

    .fursat__left {
      order: 2;
      padding: 24px 20px 40px;
      gap: 16px;
    }

    /* Reorder left children: logo → desc → features → heading → cta */
    .fursat__logo-row {
      order: 1;
      margin-bottom: 0;
    }

    .fursat__desc-box {
      order: 2;
      max-width: 100%;
    }

    .fursat__features {
      order: 3;
    }

    .fursat__heading {
      order: 4;
      color: var(--color-brand-900);
      font-size: clamp(2.5rem, 10vw, 3rem);
      text-align: left;
      max-width: 100%;
    }

    .fursat__cta-wrap {
      order: 5;
      align-items: center;
      max-width: 100%;
    }

    /* Hide quote box on mobile — not in Figma design */
    .fursat__quote-box {
      display: none;
    }
  }
</style>
