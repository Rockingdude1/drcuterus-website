---
import { Image } from 'astro:assets';
import fursatPhoto from '../assets/images/fursat-photo.png';
import fursatLogo from '../assets/images/fursat-logo.png';
import fursat1 from '../assets/images/fursat-1.png';
import fursat2 from '../assets/images/fursat-2.png';
import fursat3 from '../assets/images/fursat-3.png';
import fursat4 from '../assets/images/fursat-4.png';
---

<section class="fursat" id="fursat">
  <div class="fursat__left">
    <h2 class="fursat__heading">Made a bra for you</h2>

    <div class="fursat__desc-wrap">
      <div class="fursat__logo-row">
        <Image src={fursatLogo} alt="Fursat" class="fursat__logo" />
      </div>
      <div class="fursat__desc-box">
        <p class="fursat__desc">
          and I proudly present <strong>FURSAT</strong>: our <strong>cloud-soft</strong>,{" "}
          <strong>medium-impact bra</strong> designed to hold you (and your bewbies) with love.
        </p>
      </div>
    </div>

    <ul class="fursat__features">
      <li class="fursat__feature">
        <img src="/doodles/fursat-bullets.svg" alt="" class="fursat__bullet" width="23" height="23" />
        Wide straps (no angry shoulders)
      </li>
      <li class="fursat__feature">
        <img src="/doodles/fursat-bullets.svg" alt="" class="fursat__bullet" width="23" height="23" />
        Dreamy colours
      </li>
      <li class="fursat__feature">
        <img src="/doodles/fursat-bullets.svg" alt="" class="fursat__bullet" width="23" height="23" />
        Sexy backs (Justin Timberlake, we're watching)
      </li>
    </ul>

    <div class="fursat__quote-box">
      <p class="fursat__quote">
        For the girl who works hard, stretches slow, cries easy, and deserves every second of fursat.
      </p>
    </div>

    <div class="fursat__cta-wrap">
      <a href="https://letstilt.com/collections/fursat-bras" target="_blank" rel="noopener" class="btn-primary fursat__cta">Order your Fursat Now</a>
      <p class="fursat__cta-sub">and your boobs will thank you.</p>
    </div>
  </div>

  <div class="fursat__right">
    <div class="fursat__photo-wrap">

      <!-- Desktop: original single photo — wrapper div is the flex/grid child -->
      <div class="fursat__frame fursat__frame--desktop">
        <Image src={fursatPhoto} alt="Fursat bras collection" class="fursat__photo" />
      </div>

      <!-- Tablet + Mobile: colour variant photos — each wrapper is toggled via JS -->
      <div class="fursat__frame fursat__frame--variant is-active" data-variant="1">
        <Image src={fursat1} alt="Fursat bra colour 1" class="fursat__photo" />
      </div>
      <div class="fursat__frame fursat__frame--variant" data-variant="2">
        <Image src={fursat2} alt="Fursat bra colour 2" class="fursat__photo" />
      </div>
      <div class="fursat__frame fursat__frame--variant" data-variant="3">
        <Image src={fursat3} alt="Fursat bra colour 3" class="fursat__photo" />
      </div>
      <div class="fursat__frame fursat__frame--variant" data-variant="4">
        <Image src={fursat4} alt="Fursat bra colour 4" class="fursat__photo" />
      </div>

      <!-- Colour swatches (tablet + mobile only) -->
      <div class="fursat__swatches">
        <button class="fursat__swatch fursat__swatch--1 is-active" data-variant="1" type="button" aria-label="Colour 1"></button>
        <button class="fursat__swatch fursat__swatch--2" data-variant="2" type="button" aria-label="Colour 2"></button>
        <button class="fursat__swatch fursat__swatch--3" data-variant="3" type="button" aria-label="Colour 3"></button>
        <button class="fursat__swatch fursat__swatch--4" data-variant="4" type="button" aria-label="Colour 4"></button>
      </div>
    </div>
  </div>
</section>

<style>
  .fursat {
    background-color: var(--color-beige-500);
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 100svh;
    overflow: hidden;
  }

  /* ── LEFT ── */
  .fursat__left {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 80px 40px 60px 60px;
    gap: 20px;
  }

  .fursat__desc-wrap {
    position: relative;
    width: 100%;
    max-width: 520px;
  }

  .fursat__logo-row {
    position: absolute;
    top: 0;
    left: 0;
    transform: translate(-15%, -45%);
    z-index: 2;
  }

  .fursat__logo {
    width: 68px;
    height: auto;
    transform: rotate(-10deg);
  }

  .fursat__heading {
    font-family: var(--font-display);
    font-weight: 500;
    font-style: italic;
    font-size: clamp(2rem, 3.5vw, 3rem);
    color: var(--color-brand-400);
    margin: 0;
    letter-spacing: -0.06em;
    line-height: 1;
    text-align: center;
    max-width: 520px;
  }

  .fursat__desc-box {
    background-color: var(--color-brand-100);
    padding: 12px 16px;
    max-width: 520px;
  }

  .fursat__desc {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1.25rem;
    color: var(--color-black);
    margin: 0;
    line-height: 1.2;
  }

  .fursat__features {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
    width: 100%;
    max-width: 520px;
  }

  .fursat__feature {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1.3rem;
    color: var(--color-black);
    line-height: 1;
  }

  .fursat__bullet {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .fursat__quote-box {
    border: 1px solid var(--color-black);
    border-radius: 100px;
    padding: 12px 24px;
    max-width: 520px;
  }

  .fursat__quote {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1.3rem;
    color: var(--color-black);
    margin: 0;
    line-height: 1.5;
  }

  .fursat__cta-wrap {
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: center;
    max-width: 520px;
  }

  .fursat__cta {
    font-size: 1rem;
  }

  .fursat__cta-sub {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-black);
    margin: 0;
  }

  /* ── RIGHT — desktop ── */
  .fursat__right {
    overflow: hidden;
    background-color: var(--color-beige-500);
    display: flex;
    align-items: center;
    justify-content: center;
    padding-top: 80px;
  }

  /* photo-wrap is the positioning context for swatches + frames */
  .fursat__photo-wrap {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Desktop frame — fills the flex container */
  .fursat__frame--desktop {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .fursat__photo {
    width: 100%;
    height: 100%;
    max-height: calc(100svh - 80px);
    object-fit: contain;
    object-position: right center;
    display: block;
  }

  /* Variant frames + swatches: hidden on desktop */
  .fursat__frame--variant {
    display: none;
  }

  .fursat__swatches {
    display: none;
  }


  /* ── TABLET + MOBILE: colour switcher ── */
  @media (max-width: 1024px) {
    /* Hide desktop frame */
    .fursat__frame--desktop {
      display: none;
    }

    /* photo-wrap becomes a position context (no flex layout needed) */
    .fursat__photo-wrap {
      display: block;
    }

    /* All variant frames fill the container; only .is-active is visible */
    .fursat__frame--variant {
      display: none;
      position: absolute;
      inset: 0;
    }

    .fursat__frame--variant.is-active {
      display: block;
    }

    /* Photo inside a variant frame fills it fully */
    .fursat__frame--variant .fursat__photo {
      width: 100%;
      height: 100%;
      max-height: unset;
      object-fit: cover;
      object-position: center top;
    }

    /* Swatches: vertical column, right-aligned */
    .fursat__swatches {
      display: flex;
      flex-direction: column;
      gap: 10px;
      position: absolute;
      right: 12px;
      top: 50%;
      transform: translateY(-50%);
      z-index: 2;
    }

    .fursat__swatch {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      border: 2px solid transparent;
      cursor: pointer;
      padding: 0;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.25);
      transition: border-color 0.2s ease, transform 0.15s ease;
    }

    .fursat__swatch.is-active {
      transform: scale(1.12);
    }

    .fursat__swatch--1 { background-color: #C5A882; }
    .fursat__swatch--2 { background-color: #222020; }
    .fursat__swatch--3 { background-color: #D49BB5; }
    .fursat__swatch--4 { background-color: #6BCECA; }

    .fursat__swatch--1.is-active { border-color: #9E6229; }
    .fursat__swatch--2.is-active { border-color: #000000; }
    .fursat__swatch--3.is-active { border-color: #965462; }
    .fursat__swatch--4.is-active { border-color: #1F625D; }
  }

  /* ── TABLET (769–1024px) ── */
  @media (max-width: 1024px) and (min-width: 769px) {
    .fursat__left {
      padding: 48px 24px 48px 32px;
    }

    .fursat__heading,
    .fursat__desc-box,
    .fursat__features,
    .fursat__cta-wrap {
      max-width: 90%;
    }

    /* Keep right column height so photo-wrap + swatches work */
    .fursat__right {
      padding-top: 80px;
    }

    .fursat__photo-wrap {
      height: 100%;
    }
  }

  /* ── MOBILE ── */
  @media (max-width: 768px) {
    .fursat {
      display: flex;
      flex-direction: column;
      height: 100svh;
      padding-top: 56px;
      overflow: hidden;
    }

    /* Image section: top, yellow background */
    .fursat__right {
      order: 1;
      flex-shrink: 0;
      height: 38svh;
      padding: 0;
      min-height: unset;
      background-color: #ffe07f;
      /* Override desktop flex centering so photo-wrap anchors to the top */
      align-items: flex-start;
      justify-content: flex-start;
    }

    .fursat__photo-wrap {
      width: 100%;
      height: 100%;
    }

    /* Left fills remaining space */
    .fursat__left {
      order: 2;
      flex: 1;
      padding: 12px 20px 16px;
      gap: 8px;
    }

    /* Space for absolutely-positioned logo to peek above */
    .fursat__desc-wrap {
      margin-top: 24px;
      width: 100%;
      max-width: 100%;
    }

    /* Move logo slightly higher on mobile */
    .fursat__logo-row {
      order: 1;
      margin-bottom: 0;
      transform: translate(-15%, -60%);
    }

    .fursat__desc-box {
      order: 2;
      max-width: 100%;
      padding: 8px 14px;
    }

    .fursat__desc {
      font-size: 0.875rem;
      line-height: 1.4;
    }

    .fursat__features {
      order: 3;
      gap: 4px;
      width: 100%;
      max-width: 100%;
    }

    .fursat__feature {
      font-size: 0.875rem;
      gap: 8px;
    }

    .fursat__bullet {
      width: 18px;
      height: 18px;
    }

    .fursat__heading {
      order: 4;
      color: var(--color-brand-900);
      font-size: clamp(1.5rem, 7vw, 2rem);
      text-align: center;
      max-width: 100%;
      margin-top: 6px;
    }

    .fursat__cta-wrap {
      order: 5;
      align-items: center;
      max-width: 100%;
      gap: 4px;
    }

    .fursat__cta {
      font-size: 0.9375rem;
      padding: 8px 16px;
    }

    .fursat__cta-sub {
      font-size: 0.75rem;
    }

    /* Quote box hidden on mobile */
    .fursat__quote-box {
      display: none;
    }

    /* Slightly smaller swatches on mobile */
    .fursat__swatch {
      width: 38px;
      height: 38px;
    }

    .fursat__swatches {
      right: 8px;
      gap: 8px;
    }
  }

  /* ── Small phones (iPhone SE, etc.) ── */
  @media (max-width: 768px) and (max-height: 700px) {
    .fursat__right {
      height: 34svh;
    }

    .fursat__left {
      padding: 8px 20px 12px;
      gap: 6px;
    }

    .fursat__desc-wrap {
      margin-top: 16px;
    }

    .fursat__heading {
      font-size: clamp(1.25rem, 6vw, 1.5rem);
    }

    .fursat__desc {
      font-size: 0.8rem;
    }

    .fursat__feature {
      font-size: 0.8rem;
    }
  }
</style>

<script>
  const wrap = document.querySelector<HTMLElement>('.fursat__photo-wrap');
  if (wrap) {
    wrap.querySelectorAll<HTMLButtonElement>('.fursat__swatch').forEach(btn => {
      btn.addEventListener('click', () => {
        const variant = btn.dataset.variant;
        // Update active swatch
        wrap.querySelectorAll('.fursat__swatch').forEach(s => s.classList.remove('is-active'));
        btn.classList.add('is-active');
        // Update active frame
        wrap.querySelectorAll('.fursat__frame--variant').forEach(f => f.classList.remove('is-active'));
        wrap.querySelector<HTMLElement>(`.fursat__frame--variant[data-variant="${variant}"]`)?.classList.add('is-active');
      });
    });
  }
</script>
