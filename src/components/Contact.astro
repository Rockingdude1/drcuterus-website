---
import { Image } from 'astro:assets';
import contactPhoto from '../assets/images/contact-photo.jpeg';
import samosaPhoto from '../assets/images/samosa.jpeg';
---

<section class="contact" id="contact">
  <div class="contact__photo-col">
    <Image
      src={contactPhoto}
      alt="Dr. Tanaya Narendra"
      class="contact__photo"
      widths={[400, 700, 1000]}
      sizes="(max-width: 768px) 100vw, 50vw"
    />
    <img src="/doodles/contact-cutout.svg" class="contact__cutout" alt="" aria-hidden="true" />
  </div>

  <div class="contact__content">
    <div class="contact__text">
      <div class="contact__heading-wrap">
        <img src="/doodles/contact-flower-yellow.svg" class="contact__flower contact__flower--yellow" alt="" />
        <img src="/doodles/contact-flower-purple.svg" class="contact__flower contact__flower--purple" alt="" />
        <h2 class="contact__heading">
          Found something you liked?<br />Let's talk.
        </h2>
      </div>

      <p class="contact__subheading">
        For collabs, speaking, and partnerships or just to say hi!
      </p>

      <div class="contact__ctas">
        <a href="https://mail.google.com/mail/?view=cm&to=drcuterus@gmail.com" target="_blank" rel="noopener" class="btn-primary">Work With Me</a>
        <a href="#" class="btn-outline">See My Content</a>
      </div>

      <div class="contact__samosa">
        <p class="contact__samosa-text">Samosa says hi!</p>
        <Image
          src={samosaPhoto}
          alt="Samosa, Dr. Cuterus's dog"
          class="contact__samosa-img"
          width={140}
          height={140}
        />
      </div>

      <img src="/doodles/arrow-1.svg" class="contact__arrow" alt="" width="60" height="62" />

      <div class="contact__footer">
        <div class="contact__footer-top">
          <p class="contact__email">
            Can also reach out on:
            <a href="https://mail.google.com/mail/?view=cm&to=drcuterus@gmail.com" target="_blank" rel="noopener" class="contact__email-link">drcuterus@gmail.com</a>
          </p>
        </div>
        <div class="contact__footer-divider-wrap">
          <div class="contact__footer-divider"></div>
        </div>
        <p class="contact__socials">
          Learn about your body on:
          <a href="https://www.instagram.com/dr_cuterus/" target="_blank" rel="noopener" class="contact__social-link">Instagram</a>
          <a href="https://www.youtube.com/@dr_cuterus" target="_blank" rel="noopener" class="contact__social-link">Youtube</a>
          <a href="https://open.spotify.com/show/41cmfHeXZXHs1xuLV5rJdD" target="_blank" rel="noopener" class="contact__social-link">Spotify</a>
        </p>
      </div>
    </div>
  </div>
</section>

<div class="contact__pattern-strip">
  <span class="contact__strip-copy">© 2026 Tanaya Narendra. All rights reserved.</span>
  <span class="contact__strip-credit">Designed &amp; Developed by <a href="https://mail.google.com/mail/?view=cm&to=sanvikhandelwal2005@gmail.com" target="_blank" rel="noopener" class="contact__strip-link">ReWired Labs</a></span>
</div>

<style>
  .contact__pattern-strip {
    background-color: var(--color-brand-100);
    background-image:
      linear-gradient(rgba(110, 57, 151, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(110, 57, 151, 0.08) 1px, transparent 1px);
    background-size: 40px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 60px;
    min-height: 48px;
  }

  .contact__strip-copy {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--color-brand-900);
    opacity: 0.85;
  }

  .contact__strip-credit {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--color-brand-900);
    opacity: 0.9;
  }

  .contact__strip-link {
    color: var(--color-brand-400);
    text-decoration: none;
    font-weight: 600;
  }

  .contact__strip-link:hover {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .contact__pattern-strip {
      flex-direction: column-reverse;
      align-items: center;
      text-align: center;
      padding: 16px 20px;
      gap: 8px;
    }
  }

  .contact {
    background-color: var(--color-beige-500);
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 100svh;
    overflow: hidden;
  }

  /* PHOTO COLUMN */
  .contact__photo-col {
    background-color: var(--color-yellow-500);
    position: relative;
    overflow: hidden;
  }

  .contact__photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    display: block;
  }

  .contact__cutout {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    z-index: 2;
  }

  /* CONTENT COLUMN */
  .contact__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 140px 60px 32px 40px;
    position: relative;
    background-color: var(--color-beige-500);
  }

  .contact__text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 16px;
    position: relative;
    z-index: 1;
    min-height: 100%;
  }

  .contact__heading-wrap {
    position: relative;
    padding: 40px 0 0;
  }

  .contact__flower {
    position: absolute;
    width: 48px;
    height: 46px;
    display: block;
    pointer-events: none;
    z-index: -1;
  }

  .contact__flower--yellow {
    top: clamp(34px, 4vw, 50px);
    left: clamp(10px, 2vw, 30px);
  }

  .contact__flower--purple {
    top: clamp(72px, 8vw, 85px);
    right: clamp(56px, 12vw, 180px);
  }

  .contact__heading {
    font-family: var(--font-display);
    font-weight: 500;
    font-style: italic;
    font-size: clamp(2rem, 3.5vw, 2.5rem);
    color: var(--color-brand-900);
    margin: 0 0 12px;
    line-height: 0.95;
    letter-spacing: -0.06em;
    text-align: center;
  }

  .contact__subheading {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1.1rem;
    color: var(--color-brand-900);
    margin: 0 0 12px;
    max-width: 600px;
    text-align: center;
    align-self: center;
  }

  .contact__ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 32px;
    justify-content: center;
  }

  .contact__samosa {
    display: flex;
    align-items: center;
    gap: 16px;
    align-self: flex-end;
    margin-bottom: 20px;
  }

  .contact__samosa-text {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1.25rem;
    color: var(--color-brand-900);
    margin: 0;
  }

  .contact__samosa-img {
    width: 140px;
    height: 140px;
    object-fit: cover;
    border-radius: 50%;
  }

  .contact__arrow {
    position: absolute;
    width: 72px;
    height: auto;
    bottom: 80px;
    left: 12px;
    transform: rotate(180deg) scaleY(-1);
    opacity: 0.8;
  }

  /* FOOTER */
  .contact__footer {
    border-top: none;
    margin-top: auto;
  }

  .contact__footer-top {
    margin-bottom: 4px;
  }

  .contact__email {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-brand-900);
    margin: 0 0 4px;
    text-align: right;
  }

  .contact__email-link {
    color: var(--color-brand-900);
    text-decoration: underline;
    text-decoration-color: var(--color-brand-400);
    text-underline-offset: 2px;
  }

  .contact__footer-divider-wrap {
    margin-bottom: 6px;
  }

  .contact__footer-divider {
    width: 100%;
    height: 1px;
    background-color: var(--color-brand-900);
    opacity: 0.3;
  }

  .contact__socials {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-brand-900);
    margin: 0 0 8px;
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .contact__social-link {
    color: var(--color-brand-400);
    font-weight: 500;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .contact__social-link:hover {
    color: var(--color-brand-600);
    text-decoration: underline;
  }

  .contact__copyright {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-brand-900);
    margin: 0;
    text-align: center;
  }

  /* TABLET (769–1024px) */
  @media (max-width: 1024px) and (min-width: 769px) {
    .contact__content {
      padding: 40px 32px 24px 28px;
    }

    .contact__flower--purple {
      right: 80px;
    }

    .contact__samosa-img {
      width: min(120px, 15vw);
      height: min(120px, 15vw);
    }
  }

  /* MOBILE */
  @media (max-width: 768px) {
    .contact {
      display: flex;
      flex-direction: column;
      height: 100svh;
      padding-top: 56px;
      overflow: hidden;
    }

    /* Photo fully visible below navbar */
    .contact__photo-col {
      height: 30svh;
      flex-shrink: 0;
    }

    .contact__photo {
      min-height: auto;
    }

    /* Content fills remaining space */
    .contact__content {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      padding: 16px 20px 8px;
    }

    .contact__text {
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      gap: 10px;
    }

    .contact__heading-wrap {
      padding-top: 0;
    }

    .contact__heading {
      margin-top: 0;
      text-align: center;
      font-size: clamp(1.75rem, 8vw, 2.5rem);
      line-height: 0.9;
    }

    .contact__subheading {
      font-size: 0.9375rem;
      margin-bottom: 0;
      line-height: 1.25;
      text-wrap: balance;
    }

    .contact__ctas {
      justify-content: center;
      gap: 10px;
      margin-bottom: 8px;
    }

    .contact__ctas :global(a) {
      min-width: 148px;
      justify-content: center;
    }

    .contact__samosa {
      align-self: stretch;
      justify-content: center;
      gap: 12px;
      margin-bottom: 0;
    }

    .contact__samosa-text {
      font-size: 1.1rem;
      line-height: 1.1;
    }

    .contact__samosa-img {
      width: clamp(80px, 22vw, 108px);
      height: clamp(80px, 22vw, 108px);
    }

    .contact__arrow {
      display: none;
    }

    .contact__flower {
      width: 40px;
      height: 38px;
    }

    .contact__flower--yellow {
      top: 2px;
      left: 10px;
    }

    .contact__flower--purple {
      top: 68px;
      right: 12px;
    }

    .contact__footer {
      margin-top: 8px;
      padding-top: 8px;
    }

    .contact__socials {
      justify-content: center;
      gap: 10px;
      margin-bottom: 8px;
    }

    .contact__email {
      text-align: center;
      line-height: 1.35;
      margin-bottom: 4px;
    }
  }

  /* Small phones (iPhone SE etc.) */
  @media (max-width: 768px) and (max-height: 700px) {
    .contact__photo-col {
      height: 26svh;
    }

    .contact__content {
      padding: 10px 20px 8px;
    }

    .contact__text {
      gap: 8px;
    }

    .contact__heading {
      font-size: clamp(1.5rem, 7vw, 2rem);
    }

    .contact__subheading {
      font-size: 0.875rem;
    }

    .contact__samosa {
      display: none;
    }

    .contact__footer {
      margin-top: 4px;
    }
  }
</style>
