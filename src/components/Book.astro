---
import { Image } from 'astro:assets';
import bookCoverEn from '../assets/images/book-cover-en.jpg';

const languages = [
  { label: "English", href: "#", coverSrc: bookCoverEn.src },
  { label: "Hindi", href: "#", coverSrc: "/images/book-cover-hindi-placeholder.svg" },
  { label: "Punjabi", href: "#", coverSrc: "/images/book-cover-punjabi-placeholder.svg" },
];
---

<section class="book" id="book">
  <!-- DOM order matches mobile flow; desktop uses explicit grid placement -->

  <!-- Mobile row 1 / Desktop col 3 row 1: tags, title, author, rating -->
  <div class="book__right">
    <div class="book__tags">
      <span class="book__tag">Sexual Health Awareness</span>
      <span class="book__tag">Educational/Self Help</span>
    </div>
    <h2 class="book__title">
      Everything Nobody Tells You About Your Body
    </h2>
    <p class="book__author">By Tanaya Narendra</p>
    <div class="book__rating">
      <div class="book__stars" aria-label="4.5 out of 5 stars">
        <span class="book__star">★</span>
        <span class="book__star">★</span>
        <span class="book__star">★</span>
        <span class="book__star">★</span>
        <span class="book__star book__star--half">★</span>
      </div>
      <p class="book__rating-text">
        4.5 rating on <span class="book__goodreads">GoodReads</span>
        <img src="/doodles/book-underline.svg" class="book__goodreads-underline" alt="" />
      </p>
    </div>
  </div>

  <!-- Mobile row 2 / Desktop col 1 row 1: quote (desktop only) + lang section -->
  <div class="book__left">
    <div class="book__quote-wrap">
      <blockquote class="book__quote">
        <span class="book__quote-mark">“</span>   Even though everyone has a body, nobody wants to talk about it. Especially those 'private' bits.<span class="book__quote-mark book__quote-mark--close">”</span>
      </blockquote>
    </div>

    <div class="book__lang-section">
      <p class="book__lang-label">Select Language.</p>
      <div class="book__lang-selector" id="lang-selector">
        <span class="book__lang-read">READ IN</span>
        <button class="book__lang-current" id="lang-btn" aria-haspopup="listbox" aria-expanded="false">
          <span id="lang-current-text">English</span>
          <span class="book__lang-chevron" aria-hidden="true"></span>
        </button>
        <ul class="book__lang-dropdown" id="lang-dropdown" role="listbox" aria-label="Select language">
          {languages.map((lang) => (
            <li
              class="book__lang-option"
              role="option"
              data-href={lang.href}
              data-cover={lang.coverSrc}
              data-label={lang.label}
            >
              {lang.label}
            </li>
          ))}
        </ul>
      </div>
      <img src="/doodles/book-lang-arrow.svg" class="book__lang-arrow" alt="" width="42" height="157" />
    </div>
  </div>

  <!-- Mobile row 3 / Desktop col 2 rows 1-2: book cover -->
  <div class="book__center">
    <Image
      src={bookCoverEn}
      alt="Everything Nobody Tells You About Your Body — Dr. Tanaya Narendra"
      class="book__cover"
      id="book-cover-img"
      widths={[300, 500, 700]}
      sizes="(max-width: 768px) 70vw, 300px"
    />
  </div>

  <!-- Mobile row 4 / Desktop col 3 row 2: buy button -->
  <div class="book__buy-wrap">
    <a href="#" class="btn-primary book__buy-btn" id="book-buy-btn">Buy My Book →</a>
  </div>

  <!-- Mobile row 5 / Desktop col 1 row 2: who should read this -->
  <div class="book__who">
    <p class="book__who-title">Who should read this?</p>
    <img src="/doodles/arrow-1.svg" class="book__who-arrow" alt="" width="60" height="62" />
    <div class="book__divider"></div>
    <p class="book__who-answer">
      <span class="book__who-hinglish">Agar aapne kabhi Google pe kuch poochha jo doctor ke saamne poochhhne mein sharam aati toh yeh book aapke liye hai.</span>
      <span class="book__who-english">If you've ever Googled something you were too embarrassed to ask your doctor, then this book is for you.</span>
    </p>
  </div>

  <!-- Reviews banner -->
  <div class="book__reviews">
    <p class="book__reviews-text">Reviews' coming soon — stay tuned!</p>
  </div>
</section>

<style>
  .book {
    background-color: var(--color-brand-100);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    grid-template-rows: 3fr auto auto 7fr;
    min-height: 100svh;
    padding-top: 80px;
    position: relative;
    overflow: hidden;
  }

  /* Explicit desktop grid placement */
  /* Row 1 (1fr): top spacer — Row 4 (1fr): reviews — extra height splits equally top/bottom */
  .book__right   { grid-column: 3; grid-row: 2; }
  .book__left    { grid-column: 1; grid-row: 2; }
  .book__center  { grid-column: 2; grid-row: 2 / 4; }
  .book__buy-wrap{ grid-column: 3; grid-row: 3; }
  .book__who     { grid-column: 1; grid-row: 3; }
  .book__reviews { grid-column: 1 / -1; grid-row: 4; }

  /* LEFT */
  .book__left {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding: 16px 24px 40px 60px;
    gap: 32px;
  }

  .book__quote-wrap {
    background-color: var(--color-yellow-500);
    padding: 6px 10px;
    border-radius: 4px;
    position: relative;
    color: var(--color-brand-900);
  }

  .book__quote-mark {
    font-family: var(--font-display);
    font-weight: 500;
    font-style: italic;
    font-size: 2rem;
    color: var(--color-brand-900);
    line-height: 0;
    display: inline;
    vertical-align: -0.3em;
  }

  .book__quote-mark--close {
    display: inline-block;
    vertical-align: -0.3em;
  }

  .book__quote {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1.25rem;
    color: var(--color-brand-900);
    margin: 4px 0 0;
    line-height: 1.5;
  }

  .book__lang-section {
    display: flex;
    flex-direction: column;
    gap: 8px;
    position: relative;
  }

  .book__lang-label {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 1.125rem;
    color: var(--color-brand-900);
    margin: 0;
  }

  .book__lang-selector {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--color-beige-500);
    border-radius: 999px;
    padding: 8px 16px;
    width: fit-content;
    box-shadow: 0 0 4px rgba(0,0,0,0.25);
    position: relative;
  }

  .book__lang-read {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 400;
    text-transform: uppercase;
    color: var(--color-brand-900);
    line-height: 1;
  }

  .book__lang-current {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--color-brand-400);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    line-height: 1;
  }

  .book__lang-chevron {
    display: inline-block;
    width: 7px;
    height: 7px;
    border-right: 2px solid var(--color-yellow-500);
    border-bottom: 2px solid var(--color-yellow-500);
    transform: rotate(45deg);
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }

  .book__lang-current[aria-expanded="true"] .book__lang-chevron {
    transform: rotate(-135deg);
  }

  .book__lang-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    right: 0;
    background: var(--color-beige-500);
    border-radius: 12px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.15);
    list-style: none;
    margin: 0;
    padding: 8px 0;
    z-index: 10;
  }

  .book__lang-dropdown.is-open {
    display: block;
  }

  .book__lang-option {
    padding: 10px 16px;
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--color-brand-900);
    cursor: pointer;
    transition: background-color 0.15s ease;
  }

  .book__lang-option:hover {
    background-color: var(--color-brand-50);
  }

  .book__lang-arrow {
    position: absolute;
    bottom: -120px;
    left: 200px;
    width: 42px;
    height: auto;
    transform: rotate(126deg);
    opacity: 0.7;
    pointer-events: none;
  }

  /* WHO SECTION */
  .book__who {
    padding: 20px 24px 40px 60px;
    position: relative;
  }

  .book__who-title {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1.25rem;
    color: var(--color-brand-900);
    margin: 0 0 8px 0;
    text-align: right;
  }

  .book__who-arrow {
    position: absolute;
    right: 0;
    top: -50px;
    width: 60px;
    height: 62px;
    transform: rotate(-90deg) scaleY(-1);
    opacity: 0.7;
  }

  .book__divider {
    width: 100%;
    height: 1px;
    background-color: var(--color-brand-900);
    opacity: 0.3;
    margin-bottom: 12px;
  }

  .book__who-answer {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 1rem;
    color: var(--color-brand-900);
    margin: 0;
    text-align: right;
    line-height: 1.5;
  }

  /* CENTER */
  .book__center {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 70px 20px 40px;
  }

  .book__cover {
    width: min(300px, 40vw);
    height: auto;
    object-fit: cover;
    box-shadow: 0 2px 8px 4px rgba(61,31,92,0.2);
    display: block;
  }

  /* RIGHT */
  .book__right {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding: 16px 60px 40px 24px;
    gap: 20px;
  }

  .book__tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .book__tag {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-brand-900);
    border: 1px solid var(--color-brand-900);
    border-radius: 999px;
    padding: 6px 12px;
    white-space: nowrap;
  }

  .book__title {
    font-family: var(--font-display);
    font-weight: 500;
    font-style: italic;
    font-size: clamp(1.75rem, 3vw, 3rem);
    color: var(--color-brand-400);
    margin: 0;
    line-height: 0.95;
    letter-spacing: -0.06em;
  }

  .book__author {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1.1rem;
    color: rgba(28, 20, 23, 0.7);
    margin: 0;
  }

  .book__rating {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .book__stars {
    display: flex;
    gap: 2px;
  }

  .book__star {
    font-size: 1.75rem;
    color: var(--color-yellow-500);
    -webkit-text-stroke: 1px var(--color-brand-400);
    line-height: 1;
  }

  .book__star--half {
    position: relative;
    display: inline-block;
    color: var(--color-brand-400);
    -webkit-text-stroke: 1px var(--color-brand-400);
  }

  .book__star--half::before {
    content: '★';
    position: absolute;
    left: 0;
    top: 0;
    width: 50%;
    overflow: hidden;
    color: var(--color-yellow-500);
    -webkit-text-stroke: 0px;
  }

  .book__rating-text {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-brand-900);
    margin: 0;
    position: relative;
    display: inline-block;
  }

  .book__goodreads {
    position: relative;
  }

  .book__goodreads-underline {
    position: absolute;
    bottom: -13px;
    left: -140px;
    width: 100%;
    height: 17px;
    pointer-events: none;
    object-fit: fill;
  }

  /* BUY WRAP */
  .book__buy-wrap {
    display: flex;
    align-items: flex-start;
    justify-content: flex-start;
    padding: 0 60px 40px 24px;
  }

  .book__buy-btn {
    font-size: 1.25rem;
    padding: 14px 28px;
  }

  /* REVIEWS BANNER */
  .book__reviews {
    background-color: var(--color-beige-500);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px;
    border-top: 1px solid rgba(61,31,92,0.1);
  }

  .book__reviews-text {
    font-family: var(--font-display);
    font-weight: 500;
    font-style: italic;
    font-size: clamp(1.25rem, 2.5vw, 2rem);
    color: var(--color-brand-400);
    margin: 0;
    letter-spacing: -0.06em;
  }

  /* ── LANGUAGE VARIANTS ── */
  .book__who-english {
    display: none;
  }

  :global([data-lang="english"]) .book__who-english {
    display: inline;
  }

  :global([data-lang="english"]) .book__who-hinglish {
    display: none;
  }

  /* MOBILE */
  @media (max-width: 768px) {
    .book {
      display: flex;
      flex-direction: column;
      min-height: 100svh;
      padding-top: 80px;
    }

    /* DOM order: right → left → center → buy-wrap → who → reviews */

    .book__right {
      padding: 24px 24px 0;
      gap: 12px;
    }

    .book__left {
      padding: 20px 24px 0;
      gap: 12px;
    }

    .book__quote-wrap {
      display: none;
    }

    .book__lang-arrow {
      display: none;
    }

    .book__center {
      padding: 20px 24px 0;
      justify-content: center;
    }

    .book__cover {
      width: min(240px, 70vw);
      margin: 0 auto;
      display: block;
    }

    .book__buy-wrap {
      padding: 24px 24px 0;
      justify-content: center;
    }

    .book__buy-btn {
      font-size: 1.1rem;
      padding: 12px 28px;
    }

    .book__who {
      padding: 24px 24px 16px;
    }

    .book__who-title {
      text-align: left;
    }

    .book__who-arrow {
      display: none;
    }

    .book__who-answer {
      text-align: left;
    }

    .book__reviews {
      margin-top: 16px;
    }
  }
</style>

<script>
  const langBtn = document.getElementById('lang-btn') as HTMLButtonElement;
  const langDropdown = document.getElementById('lang-dropdown') as HTMLElement;
  const langCurrentText = document.getElementById('lang-current-text') as HTMLElement;
  const bookCoverImg = document.getElementById('book-cover-img') as HTMLImageElement;
  const bookBuyBtn = document.getElementById('book-buy-btn') as HTMLAnchorElement;

  langBtn?.addEventListener('click', () => {
    const isOpen = langDropdown.classList.toggle('is-open');
    langBtn.setAttribute('aria-expanded', String(isOpen));
  });

  langDropdown?.querySelectorAll('.book__lang-option').forEach((option) => {
    option.addEventListener('click', () => {
      const el = option as HTMLElement;
      const label = el.dataset.label || 'English';
      const href = el.dataset.href || '#';
      const cover = el.dataset.cover || '';

      langCurrentText.textContent = label;
      if (cover) bookCoverImg.src = cover;
      if (bookBuyBtn) bookBuyBtn.href = href;

      langDropdown.classList.remove('is-open');
      langBtn.setAttribute('aria-expanded', 'false');
    });
  });

  document.addEventListener('click', (e) => {
    if (!langBtn?.contains(e.target as Node) && !langDropdown?.contains(e.target as Node)) {
      langDropdown?.classList.remove('is-open');
      langBtn?.setAttribute('aria-expanded', 'false');
    }
  });
</script>
