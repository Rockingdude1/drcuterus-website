---
---

<div id="page-loader" aria-hidden="true" role="presentation">
  <div id="loader-panel"></div>
  <span id="loader-title">Dr. Cuterus</span>
</div>

<style>
  /* Phase 1 — grid pattern (same as footer) */
  #page-loader {
    position: fixed;
    inset: 0;
    z-index: 99999;
    overflow: hidden;
    background-color: var(--color-brand-100);
    background-image:
      linear-gradient(rgba(110, 57, 151, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(110, 57, 151, 0.08) 1px, transparent 1px);
    background-size: 40px 40px;
  }

  /* Phase 2 — solid purple panel, starts entirely below viewport */
  #loader-panel {
    position: absolute;
    inset: 0;
    background-color: var(--color-brand-200);
    transform: translateY(100%);
    will-change: transform, background-color;
  }

  /* Phase 3 — title at bottom-left (matching navbar padding), starts off-screen below */
  #loader-title {
    position: absolute;
    bottom: 40px;
    left: 60px;                              /* matches .navbar padding desktop */
    transform: translateY(calc(100vh + 250px)); /* off-screen below */
    z-index: 1;
    font-family: var(--font-display);
    font-weight: 500;
    font-style: italic;
    font-size: min(18.5vw, 30vh);            /* ≈ 250 px at 1280 × 832 */
    line-height: 1;
    color: var(--color-brand-900);
    white-space: nowrap;
    pointer-events: none;
    will-change: transform, top, left, font-size;
  }

  /* keep left-edge in sync with navbar padding at every breakpoint */
  @media (max-width: 1024px) and (min-width: 769px) {
    #loader-title { left: 32px; }
  }
  @media (max-width: 768px) {
    #loader-title { left: 20px; font-size: min(17.9vw, 30vh); }
  }
</style>

<script>
  const loader  = document.getElementById('page-loader')!;
  const panel   = document.getElementById('loader-panel')!;
  const title   = document.getElementById('loader-title')!;
  const navLogo = document.querySelector<HTMLElement>('.navbar__logo');

  if (sessionStorage.getItem('loader-seen')) {
    loader.style.display = 'none';
  } else {
    // Keep actual nav logo invisible so it doesn't ghost under the loader
    if (navLogo) {
      navLogo.style.opacity   = '0';
      navLogo.style.transition = 'opacity 0.4s ease';
    }

    let pageLoaded = document.readyState === 'complete';
    let seqDone    = false;

    if (!pageLoaded) {
      window.addEventListener('load', () => { pageLoaded = true; maybeNav(); }, { once: true });
    }

    // Both gates must be true before the nav phase fires
    function maybeNav() {
      if (seqDone && pageLoaded) startNavPhase();
    }

    const EASE = 'cubic-bezier(0.76, 0, 0.24, 1)';

    // ── Phase 1: 800 ms grid stays ──────────────────────────────────────────
    setTimeout(() => {

      // ── Phase 2: purple panel rises from bottom (800 ms) ─────────────────
      requestAnimationFrame(() => {
        panel.style.transition = `transform 0.8s ${EASE}`;
        panel.style.transform  = 'translateY(0)';
      });

      // ── Phase 3: title rises from bottom after panel is fully up (800 ms) ─
      setTimeout(() => {
        requestAnimationFrame(() => {
          title.style.transition = `transform 0.8s ${EASE}`;
          title.style.transform  = 'translateY(0)';
        });

        // ── Phase 4: hold at bottom for 400 ms, then check load gate ─────────
        setTimeout(() => {
          seqDone = true;
          maybeNav();
        }, 800 + 400); // rise(800) + hold(400)

      }, 800); // wait for panel

    }, 800); // phase 1 — grid stays

    // ── Phase 5 onwards: fires when BOTH animation seq AND page are ready ────
    function startNavPhase() {

      // — FLIP: freeze title at its current rendered px position ————————————
      const fromRect   = title.getBoundingClientRect();
      const navRect    = navLogo?.getBoundingClientRect();
      const targetSize = navLogo ? parseFloat(getComputedStyle(navLogo).fontSize) : 30;
      const targetTop  = navRect ? navRect.top + (navRect.height - targetSize) / 2 : 24;
      const targetLeft = navRect?.left ?? 60;

      title.style.transition = 'none';
      title.style.top        = `${fromRect.top}px`;
      title.style.left       = `${fromRect.left}px`;
      title.style.bottom     = 'auto';   // switch away from bottom-anchored
      title.style.transform  = 'none';
      void title.offsetWidth;            // flush reflow so transition sees the new start

      // Shrink + move to EXACT nav logo spot simultaneously
      const FLIP_MS = 700;
      title.style.transition = [
        `top ${FLIP_MS}ms ${EASE}`,
        `left ${FLIP_MS}ms ${EASE}`,
        `font-size ${FLIP_MS}ms ${EASE}`,
      ].join(', ');
      title.style.top      = `${targetTop}px`;
      title.style.left     = `${targetLeft}px`;
      title.style.fontSize = `${targetSize}px`;

      // ── Phase 6: bg turns beige in 500 ms ──────────────────────────────────
      setTimeout(() => {
        panel.style.transition      = 'background-color 0.5s ease';
        panel.style.backgroundColor = 'var(--color-beige-500)';

        // ── Phase 7: fade loader, reveal page ──────────────────────────────
        setTimeout(() => {
          sessionStorage.setItem('loader-seen', '1');
          if (navLogo) navLogo.style.opacity = '1'; // fades in with loader fade-out
          loader.style.transition = 'opacity 0.4s ease';
          loader.style.opacity    = '0';
          loader.addEventListener('transitionend', () => {
            loader.style.display = 'none';
          }, { once: true });
        }, 550); // beige completes (500 + 50 buffer)
      }, FLIP_MS + 50);
    }
  }
</script>
