---
---

<div id="page-loader" aria-hidden="true" role="presentation">
  <div class="loader__inner">
    <p class="loader__phrase" id="loader-phrase"></p>
    <div class="loader__bar">
      <div class="loader__dot" id="loader-dot"></div>
    </div>
  </div>
</div>

<style>
  #page-loader {
    position: fixed;
    inset: 0;
    z-index: 99999;
    background: var(--color-brand-400);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.6s ease;
  }

  #page-loader.fade-out {
    opacity: 0;
    pointer-events: none;
  }

  .loader__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 36px;
    padding: 0 40px;
    max-width: 720px;
    width: 100%;
  }

  .loader__phrase {
    font-family: var(--font-display);
    font-weight: 500;
    font-style: italic;
    font-size: clamp(2rem, 5vw, 3.5rem);
    color: #fff;
    letter-spacing: -0.06em;
    line-height: 1.05;
    text-align: center;
    margin: 0;
    min-height: 1.1em;
  }

  .loader__phrase .word {
    opacity: 0;
    display: inline;
    transition: opacity 0.25s ease;
  }

  .loader__phrase .word.visible {
    opacity: 1;
  }

  .loader__bar {
    position: relative;
    width: 100%;
    height: 2px;
    background: rgba(255, 255, 255, 0.25);
    border-radius: 2px;
  }

  .loader__dot {
    position: absolute;
    top: 50%;
    left: 0%;
    transform: translate(-50%, -50%);
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--color-yellow-500);
    transition: left 0.38s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: left;
  }
</style>

<script>
  const words = ['Everything', 'nobody', 'told', 'you', 'about', 'Dr. Cuterus'];
  const WORD_DELAY = 380;   // ms between each word
  const END_PAUSE  = 700;   // ms to hold after last word before fade

  const loader  = document.getElementById('page-loader')!;
  const phrase  = document.getElementById('loader-phrase')!;
  const dot     = document.getElementById('loader-dot')!;

  // Build word spans
  words.forEach((word, i) => {
    const span = document.createElement('span');
    span.className = 'word';
    span.textContent = i < words.length - 1 ? word + ' ' : word;
    phrase.appendChild(span);
  });

  const spans = phrase.querySelectorAll<HTMLElement>('.word');

  // Reveal each word and move the dot
  spans.forEach((span, i) => {
    setTimeout(() => {
      span.classList.add('visible');
      dot.style.left = `${((i + 1) / words.length) * 100}%`;
    }, i * WORD_DELAY);
  });

  const animDoneAt = words.length * WORD_DELAY + END_PAUSE;

  let animDone = false;
  let pageDone = false;

  function dismiss() {
    if (!animDone || !pageDone) return;
    loader.classList.add('fade-out');
    loader.addEventListener('transitionend', () => {
      loader.style.display = 'none';
    }, { once: true });
  }

  setTimeout(() => { animDone = true; dismiss(); }, animDoneAt);

  if (document.readyState === 'complete') {
    pageDone = true;
    dismiss();
  } else {
    window.addEventListener('load', () => { pageDone = true; dismiss(); }, { once: true });
  }
</script>
