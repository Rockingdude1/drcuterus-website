---
import { Image } from 'astro:assets';
import frontDoorSvg from '../assets/images/front of door.svg?url';
import backDoorImg  from '../assets/images/back of door.jpg';
---

<div class="columnist-outer" id="columnist">
  <section class="columnist">

    <!-- LEFT: DOOR ANIMATION -->
    <div class="columnist__door-col">
      <p class="columnist__knock">Knock to meet her.</p>
      <div class="columnist__door-scene">
        <!-- Back face — revealed as front door swings open -->
        <Image src={backDoorImg} alt="" class="columnist__door-back" aria-hidden="true" widths={[400, 800]} sizes="50vw" />
        <!-- Front face — rotates open on click, hinge on left edge -->
        <img src={frontDoorSvg} alt="Click to open the door"
             class="columnist__door-front" id="columnist-door-front"
             role="button" tabindex="0" />
      </div>
    </div>

    <!-- RIGHT: CONTENT -->
    <div class="columnist__right">
      <div class="columnist__content-group">

        <div class="columnist__badge">
          <span class="columnist__badge-hinglish">answering sex queries with</span>
          <span class="columnist__badge-hinglish">aaj ki taaza khabhar</span>
          <span class="columnist__badge-english">your Sunday paper just got</span>
          <span class="columnist__badge-english">a lot more interesting</span>
        </div>

        <h2 class="columnist__heading">Your Next Door Sexpert.</h2>

        <div class="columnist__desc-box">
          <p>Carrying forward <strong>Dr. Mahindra Watsa's</strong> legendary sex column in Mumbai Mirror; everyday, I reply to all of your queries.<span class="columnist__desc-extra"> Anyone with queries can reach out to me. It is never embarrassing to ask to know more about your own body.</span></p>
        </div>

        <a href="https://mumbaimirror.indiatimes.com/topics/dr-cuterus"
           target="_blank" rel="noopener"
           class="btn-primary columnist__cta">Read It Now →</a>

      </div>
    </div>

  </section>
</div>

<style>
  /* ── OUTER ── */
  .columnist-outer {
    position: relative;
    overflow: hidden;
    background-color: var(--color-beige-500);
    width: 100%;
    scroll-margin-top: 80px; /* accounts for sticky navbar on hash navigation */
  }

  /* ── SECTION: two-column grid ── */
  .columnist {
    width: 100%;
    display: grid;
    grid-template-columns: max(42vw, 574px) 1fr;
    min-height: 100svh;
    max-height: 900px;
  }

  /* ── LEFT: DOOR COLUMN ── */
  .columnist__door-col {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    padding-left: 88px;
    padding-top: 24px;
    padding-bottom: 24px;
  }

  /* ── KNOCK TEXT ── */
  .columnist__knock {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.2rem, 1.1vw, 1.1rem);
    color: var(--color-brand-900);
    margin: 0 0 10px 0;
    letter-spacing: 0;
  }

  /* ── 3-D PERSPECTIVE WRAPPER ── */
  .columnist__door-scene {
    position: relative;
    width: 486px;
    height: 711px;
    /* perspective on parent so the door looks 3-D as it rotates */
    perspective: 1200px;
    perspective-origin: 0% 50%; /* vanishing point at left edge = hinge */
  }

  .columnist__door-back,
  .columnist__door-front {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    object-fit: fill;
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
  }

  /* ── FRONT DOOR — the panel that swings open ── */
  .columnist__door-front {
    transform-origin: left center; /* hinge on the left */
    transition: transform 0.85s cubic-bezier(0.4, 0, 0.1, 1),
                filter  0.85s ease;
    cursor: pointer;
    will-change: transform;
  }

  /* Hover hint: door nudges ajar so users know it's interactive */
  .columnist__door-front:not(.door--open):hover {
    transform: rotateY(-9deg);
  }
  .columnist__door-front:not(.door--open):focus-visible {
    outline: 3px solid var(--color-brand-400);
    outline-offset: 4px;
    transform: rotateY(-9deg);
  }

  /* Opened state: door swings ~87° around its left (hinge) edge */
  .columnist__door-front.door--open {
    transform: rotateY(-87deg);
    filter: drop-shadow(-14px 6px 28px rgba(0, 0, 0, 0.45));
  }

  /* ── RIGHT: CONTENT ── */
  .columnist__right {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 80px 60px 40px 20px;
  }

  /* Content group stacks vertically, centred */
  .columnist__content-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    width: min(524px, 100%);
  }

  /* Badge / pill */
  .columnist__badge {
    background-color: var(--color-yellow-500);
    padding: 8px 24px;
    border-radius: 999px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .columnist__badge span {
    font-family: var(--font-display);
    font-weight: 500;
    font-style: italic;
    font-size: clamp(1.1rem, 2vw, 1.75rem);
    color: var(--color-brand-900);
    letter-spacing: -0.06em;
    line-height: 0.95;
    white-space: nowrap;
  }

  /* Heading */
  .columnist__heading {
    font-family: var(--font-display);
    font-weight: 500;
    font-style: italic;
    font-size: clamp(2rem, 3.3vw, 3rem);
    color: var(--color-brand-900);
    letter-spacing: -0.06em;
    line-height: 0.95;
    margin: 0;
    white-space: nowrap;
    text-align: center;
  }

  /* Description box */
  .columnist__desc-box {
    background-color: var(--color-brand-100);
    padding: 8px 26px;
    width: 100%;
  }

  .columnist__desc-box p {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: clamp(1rem, 1.5vw, 1.5rem);
    color: var(--color-black);
    text-align: center;
    margin: 0;
    line-height: 1.4;
  }

  .columnist__desc-box strong { font-weight: 700; }

  /* CTA */
  .columnist__cta {
    font-size: clamp(1.125rem, 2vw, 1.5rem);
    padding: 12px 24px;
  }

  /* ── LANGUAGE VARIANTS ── */
  .columnist__badge-english { display: none; }
  :global([data-lang="english"]) .columnist__badge-english  { display: inline; }
  :global([data-lang="english"]) .columnist__badge-hinglish { display: none; }

  /* ── TABLET (769–1024px) ── */
  @media (max-width: 1024px) and (min-width: 769px) {
    .columnist {
      grid-template-columns: 42vw 1fr;
    }

    .columnist__door-col {
      padding-left: 32px;
      padding-top: 100px;
    }

    .columnist__door-scene {
      /* scale door proportionally: keeps ~35 vw wide, height follows 486:711 ratio */
      width: clamp(260px, 35vw, 420px);
      height: calc(clamp(260px, 35vw, 420px) * (711 / 486));
    }

    .columnist__right {
      padding: 80px 32px 40px 16px;
    }

    .columnist__heading {
      font-size: clamp(1.75rem, 2.8vw, 2.5rem);
      white-space: normal;
    }

    .columnist__desc-box p { font-size: 1.125rem; }
    .columnist__cta { font-size: 1.125rem; padding: 10px 20px; }
  }

  /* ── MOBILE (≤768px) ── */
  @media (max-width: 768px) {
    /* Outer still fills at least the full screen.
       scroll-margin-top: 0 prevents the previous section from peeking
       at the top when scroll-snap snaps to this section. */
    .columnist-outer {
      min-height: 100svh;
      scroll-margin-top: 0;
    }

    /*
     * Flatten the two-column structure into a single centered column.
     * All items: knock → door → badge → heading → text → CTA
     * are laid out together with a fixed gap.
     * Extra space (on taller phones) accumulates as equal top/bottom margins
     * via justify-content: center — never between the items.
     */
    .columnist {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100svh;
      max-height: unset;
      padding: 20px;
      gap: 12px;
      box-sizing: border-box;
    }

    /* Remove both column wrappers from the layout — their children
       become direct flex children of .columnist */
    .columnist__door-col,
    .columnist__right {
      display: contents;
    }

    /* Hide the extra sentences on mobile — keep only the first sentence */
    .columnist__desc-extra {
      display: none;
    }

    .columnist__knock {
      font-size: 0.9rem;
      margin: 0;
      text-align: center;
    }

    .columnist__door-scene {
      width: min(270px, 68vw);
      height: calc(min(270px, 68vw) * (711 / 486));
      flex-shrink: 0;
    }

    /* Content group: badge + heading + text + CTA, tight together */
    .columnist__content-group {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      width: 100%;
      max-width: 380px;
    }

    .columnist__badge {
      padding: 6px 18px;
    }

    .columnist__badge span {
      font-size: clamp(0.875rem, 4vw, 1.1rem);
      white-space: normal;
      text-align: center;
    }

    .columnist__heading {
      font-size: clamp(1.75rem, 8vw, 2.2rem);
      white-space: normal;
      text-align: center;
      margin: 0;
    }

    .columnist__desc-box {
      padding: 6px 18px;
      width: 100%;
    }

    .columnist__desc-box p { font-size: 0.875rem; }

    .columnist__cta { font-size: 1rem; padding: 10px 20px; }
  }
</style>

<script>
  const door = document.getElementById('columnist-door-front') as HTMLElement | null;

  function toggleDoor() {
    const isOpen = door!.classList.toggle('door--open');
    door!.setAttribute('aria-label', isOpen ? 'Close the door' : 'Open the door');
  }

  door?.addEventListener('click', toggleDoor);

  door?.addEventListener('keydown', (e) => {
    if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') {
      e.preventDefault();
      toggleDoor();
    }
  });
</script>
