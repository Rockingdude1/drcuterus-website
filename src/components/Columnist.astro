---
import { Image } from 'astro:assets';
import columnistPhoto from '../assets/images/columnist-photo.jpg';
---

<div class="columnist-outer" id="columnist">

  <section class="columnist">

    <!-- LEFT: PHOTO -->
    <div class="columnist__photo-col">
      <div class="columnist__badge">
        <span class="columnist__badge-hinglish">answering sex queries with</span>
        <span class="columnist__badge-hinglish">aaj ki taaza khabhar</span>
        <span class="columnist__badge-english">your Sunday paper just got</span>
        <span class="columnist__badge-english">a lot more interesting</span>
      </div>
      <Image
        src={columnistPhoto}
        alt="Dr. Tanaya Narendra holding Mumbai Mirror"
        class="columnist__photo"
        widths={[600, 1100]}
        sizes="(max-width: 768px) 100vw, (max-width: 1024px) 42vw, 40vw"
      />
    </div>

    <!-- RIGHT: CONTENT -->
    <div class="columnist__right">

      <p class="columnist__mail-text">For sending<br/>your queries,<br/>mail to:</p>

      <div class=”columnist__quote-box”>
      </div>

      <div class="columnist__content-group">
        <h2 class="columnist__heading">Your Next Door Sexpert.</h2>

        <div class="columnist__desc-box">
          <p>Carrying forward <strong>Dr. Mahindra Watsa's</strong> legendary sex column in Mumbai Mirror, every Sunday, I reply to all of your queries. Anyone with queries can reach out to me. It is never embarrassing to ask to know more about your own body.</p>
        </div>

        <a href="https://mumbaimirror.indiatimes.com/topics/dr-cuterus" target="_blank" rel="noopener" class="btn-primary columnist__cta">Read It Now →</a>
      </div>
    </div>

  </section>

  <!-- SCRIBBLE: full viewport width, above section -->
  <img src="/doodles/columnist-scribble.svg" class="columnist__scribble" alt="" aria-hidden="true" />

  <!-- MIRROR TAG: above scribble -->
  <span class="columnist__mirror-tag">Mumbai mirror's sexpert</span>

  <!-- MOBILE SCRIBBLE: shown only on mobile -->
  <img src="/doodles/mobile-columnist-scribble.svg" class="columnist__scribble-mobile" alt="" aria-hidden="true" />

</div>

<style>
  /* ── OUTER: full viewport width ── */
  .columnist-outer {
    position: relative;
    overflow: hidden;
    background-color: var(--color-beige-500);
    width: 100%;
  }

  /* ── SECTION: full-bleed grid — photo bleeds left, content fills right ── */
  .columnist {
    width: 100%;
    display: grid;
    grid-template-columns: max(42vw, calc((100vw - 1280px) / 2 + 537.6px)) 1fr;
    height: 100svh;
    max-height: 900px;
    position: relative;
  }

  /* ── LEFT: PHOTO ── */
  .columnist__photo-col {
    position: relative;
    overflow: hidden;
    /* no margin hack needed — grid column formula handles left bleed */
  }

  .columnist__photo {
    position: absolute;
    top: 80px;
    left: 0;
    width: 100%;
    height: calc(100% - 80px);
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .columnist__badge {
    position: absolute;
    top: calc(8.33% + 63px);
    left: 61px;
    background-color: var(--color-yellow-500);
    padding: 8px 12px;
    z-index: 2;
    display: flex;
    flex-direction: column;
  }

  .columnist__badge span {
    font-family: var(--font-display);
    font-weight: 500;
    font-style: italic;
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    color: var(--color-brand-900);
    letter-spacing: -0.06em;
    line-height: 0.95;
    white-space: nowrap;
  }

  /* ── MOBILE SCRIBBLE: hidden on desktop ── */
  .columnist__scribble-mobile {
    display: none;
  }

  /* ── SCRIBBLE: full viewport width ── */
  /* width:100vw + object-fit:fill overrides the SVG's intrinsic 1281×770 aspect ratio */
  /* which would otherwise cap the width at ~1244px on larger screens */
  .columnist__scribble {
    position: absolute;
    left: 0;
    bottom: -10px;
    width: 100vw;
    height: 90%;
    object-fit: fill;
    pointer-events: none;
    z-index: 2;
  }

  /* ── MIRROR TAG: above scribble ── */
  /* left = outer left margin + 25% of 1280px + 216.57px */
  .columnist__mirror-tag {
    display: none;
    position: absolute;
    top: 60%;
    left: calc((100% - min(100%, 1280px)) / 2 + min(100%, 1280px) * 0.25 + 216.57px);
    transform: translateX(-100%) rotate(-23deg);
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--color-white);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
    pointer-events: none;
    z-index: 3;
  }

  /* ── RIGHT: CONTENT ── */
  .columnist__right {
    position: relative;
  }

  /* "For sending your queries, mail to:" */
  .columnist__mail-text {
    display: none;
    position: absolute;
    top: clamp(120px, 19.4%, 200px);
    left: calc(50% + 89px);
    transform: translateX(-50%);
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1.5rem;
    color: var(--color-brand-900);
    text-align: center;
    line-height: 1.3;
    margin: 0;
    z-index: 3;
    white-space: nowrap;
  }

  /* Quote box */
  .columnist__quote-box {
    display: none;
  }

  .columnist__quote-box p {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1.5rem;
    color: var(--color-black);
    text-align: center;
    margin: 0;
    line-height: 1.4;
  }

  .columnist__quote-open,
  .columnist__quote-close {
    display: none;
  }

  /* Group: heading + desc-box + CTA stacked naturally */
  .columnist__content-group {
    position: absolute;
    top: clamp(310px, 48%, 500px);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
    width: min(524px, 90%);
    z-index: 3;
  }

  .columnist__heading {
    font-family: var(--font-display);
    font-weight: 500;
    font-style: italic;
    font-size: clamp(2rem, 3.3vw, 3rem);
    color: var(--color-brand-900);
    letter-spacing: -0.06em;
    line-height: 0.95;
    margin: 0;
    white-space: nowrap;
    text-align: center;
  }

  /* Description box */
  .columnist__desc-box {
    background-color: var(--color-brand-100);
    padding: 8px 26px;
    width: 100%;
  }

  .columnist__desc-box p {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: clamp(1rem, 2.8svh, 1.5rem);
    color: var(--color-black);
    text-align: center;
    margin: 0;
    line-height: 1.4;
  }

  .columnist__desc-box strong {
    font-weight: 700;
  }

  /* CTA Button — flows after desc-box */
  .columnist__cta {
    font-size: clamp(1.125rem, 2vw, 1.5rem);
    padding: 12px 24px;
    z-index: 3;
  }

  /* ── LANGUAGE VARIANTS ── */
  .columnist__badge-english {
    display: none;
  }

  :global([data-lang="english"]) .columnist__badge-english {
    display: inline;
  }

  :global([data-lang="english"]) .columnist__badge-hinglish {
    display: none;
  }

  /* ── TABLET (769–1024px) ── */
  @media (max-width: 1024px) and (min-width: 769px) {
    .columnist {
      grid-template-columns: 40vw 1fr;
    }

    .columnist__badge {
      left: 32px;
    }

    /* Scale down the ± px offsets so content fits the narrower right column */
    .columnist__quote-open {
      left: max(4px, calc(50% - 180px));
    }

    .columnist__quote-box {
      display: none;
    }

    .columnist__quote-close {
      left: min(calc(100% - 4px), calc(50% + 170px));
    }

    .columnist__heading {
      left: calc(50% + 180px);
      font-size: clamp(1.75rem, 2.8vw, 2.5rem);
    }

    .columnist__desc-box {
      width: min(400px, 90%);
    }

    .columnist__desc-box p {
      font-size: 1.125rem;
    }

    .columnist__cta {
      font-size: 1.125rem;
      padding: 10px 20px;
    }
  }

  /* ── MOBILE ── */
  @media (max-width: 768px) {
    /* Outer fills exactly one screen */
    .columnist-outer {
      min-height: 100svh;
      display: flex;
      flex-direction: column;
      overflow-x: hidden;
      overflow-y: visible;
    }

    /* Section stretches to fill outer, photo on top then content below */
    .columnist {
      flex: 1;
      display: flex;
      flex-direction: column;
      height: auto;
      min-height: unset;
      max-height: unset;
    }

    /* Photo fills ~62% of screen — yellow badge stays top-left */
    .columnist__photo-col {
      height: 62svh;
      flex-shrink: 0;
      margin-left: 0;
    }

    .columnist__photo {
      top: 0;
      height: 100%;
    }

    .columnist__badge {
      top: 64px;
      left: 12px;
      padding: 5px 10px;
      z-index: 3;
    }

    .columnist__badge span {
      font-size: clamp(0.875rem, 4vw, 1.15rem);
    }

    .columnist__mirror-tag,
    .columnist__scribble {
      display: none;
    }

    .columnist__scribble-mobile {
      display: block;
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 62svh;
      object-fit: fill;
      pointer-events: none;
      z-index: 2;
    }

    /* Right col: flex:1 fills remaining space, balanced padding keeps it centered */
    .columnist__right {
      flex: 1;
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 20px 20px 28px;
      gap: 12px;
      min-height: unset;
    }

    .columnist__mail-text {
      display: none;
    }

    .columnist__quote-box {
      display: none;
    }

    /* Override desktop absolute positioning so content flows naturally */
    .columnist__content-group {
      position: static;
      transform: none;
      left: auto;
      top: auto;
      width: 100%;
      gap: 12px;
    }

    .columnist__heading {
      position: static;
      transform: none;
      font-size: clamp(1.75rem, 8vw, 2.2rem);
      text-align: center;
      white-space: normal;
    }

    .columnist__desc-box {
      position: static;
      transform: none;
      width: 100%;
      max-width: 100%;
      padding: 8px 16px;
    }

    .columnist__desc-box p {
      font-size: 0.9rem;
      text-align: center;
    }

    .columnist__cta {
      position: static;
      transform: none;
      font-size: 1rem;
      padding: 10px 20px;
    }
  }
</style>
