---
import { Image } from 'astro:assets';
import blogPhoto from '../assets/images/blog-photo.jpg';
import podcastPhoto from '../assets/images/podcast-photo.jpg';
import igThumb1 from '../assets/images/content-instagram-1.png';
import igThumb2 from '../assets/images/content-instagram-2.png';
---

<section class="content" id="content">


  <!-- Mobile-only: heading at top -->
  <div class="content__mobile-header">
    <p class="content__mobile-sub content__mobile-sub--hinglish">Mujhe dekhte hi phone ki volume kam karna band karo!</p>
    <p class="content__mobile-sub content__mobile-sub--english">Stop lowering your volume when you see me!</p>
    <h2 class="content__mobile-heading">How you will find me while scrolling on your phone</h2>
  </div>

  <!-- Mobile-only: platform pill + nav arrows -->
  <div class="content__mobile-controls">
    <span class="content__platform-pill" id="content-platform-pill">Instagram</span>
    <div class="content__mobile-nav">
      <button class="content__nav-btn" id="content-prev" aria-label="Previous platform">
        <img src="/doodles/arrow-content.svg" class="content__nav-arrow content__nav-arrow--left" alt="" />
      </button>
      <button class="content__nav-btn" id="content-next" aria-label="Next platform">
        <img src="/doodles/arrow-content.svg" class="content__nav-arrow" alt="" />
      </button>
    </div>
  </div>

  <div class="content__phones">

    <!-- Phone 1: Instagram -->
    <div class="content__mockup content__mockup--active" data-phone="0">
      <a class="content__desktop-pill" href="https://www.instagram.com/dr_cuterus/" target="_blank" rel="noopener">Instagram</a>
      <div class="content__frame">
        <div class="content__island"></div>
        <div class="content__screen content__screen--ig">

          <div class="content__profile">
            <div class="content__avatar">
              <Image
                src={blogPhoto}
                alt="Dr. Tanaya Narendra"
                class="content__avatar-img"
                width={56}
                height={56}
              />
            </div>
            <div class="content__profile-text">
              <span class="content__profile-name">Dr. Tanaya Narendra</span>
              <span class="content__profile-handle">@dr_cuterus</span>
            </div>
          </div>

          <p class="content__bio">Made for sharing 100% Science with 0% Sharam.</p>

          <div class="content__stats content__stats--ig">
            <!-- Stat 1: heart reveals 1.9M followers -->
            <div class="content__stat content__stat--reveal">
              <b class="content__stat-num">1.9 M</b>
              <span class="content__stat-label">followers</span>
              <span class="content__stat-heart" aria-hidden="true">
                <img src="/doodles/fursat-bullets.svg" width="44" height="44" alt="" />
              </span>
            </div>
            <!-- Stat 2: heart reveals 992 posts -->
            <div class="content__stat content__stat--reveal">
              <b class="content__stat-num">992</b>
              <span class="content__stat-label">posts</span>
              <span class="content__stat-heart" aria-hidden="true">
                <img src="/doodles/fursat-bullets.svg" width="44" height="44" alt="" />
              </span>
            </div>
            <!-- Stat 3: click to reveal card -->
            <div class="content__stat content__stat--ctr">
              <span class="content__stat-ctr-label">Click to reveal</span>
            </div>
          </div>

          <div class="content__grid2">
            <a class="content__thumb" href="https://www.instagram.com/reel/DUiZwPdAQgZ/" target="_blank" rel="noopener" aria-label="Watch reel on Instagram">
              <Image src={igThumb1} alt="Instagram reel" class="content__thumb-img" width={120} height={213} />
              <span class="content__thumb-play" aria-hidden="true">&#9654;</span>
            </a>
            <a class="content__thumb" href="https://www.instagram.com/reel/DYCUGZqB0eZ/" target="_blank" rel="noopener" aria-label="Watch reel on Instagram">
              <Image src={igThumb2} alt="Instagram reel" class="content__thumb-img" width={120} height={213} />
              <span class="content__thumb-play" aria-hidden="true">&#9654;</span>
            </a>
          </div>

        </div>
        <div class="content__home-bar"></div>
      </div>
    </div>

    <!-- Phone 2: Podcast -->
    <div class="content__mockup" data-phone="1">
      <a class="content__desktop-pill" href="https://open.spotify.com/show/6e1Hu3JzBxBqyXfMpXVRoS" target="_blank" rel="noopener">Spotify</a>
      <div class="content__frame">
        <div class="content__island"></div>
        <div class="content__screen content__screen--podcast">

          <!-- Large album art -->
          <div class="content__pod-art">
            <Image src={podcastPhoto} alt="The Dr. Cuterus Podcast" class="content__pod-art-img" width={220} height={220} />
          </div>

          <!-- Title + artist -->
          <p class="content__pod-title">The Dr. Cuterus Podcast</p>
          <p class="content__pod-artist">Dr. Tanaya Narendra</p>

          <!-- Listen Now + rating -->
          <div class="content__pod-actions">
            <a href="https://open.spotify.com/show/6e1Hu3JzBxBqyXfMpXVRoS" target="_blank" rel="noopener" class="content__pod-listen">Listen Now</a>
            <span class="content__pod-rating">Ratings: 4.8</span>
          </div>

          <!-- Availability footer bar -->
          <div class="content__pod-footer">
            <p class="content__pod-avail">Available on Spotify<br/>and Apple Podcasts</p>
            <a href="https://open.spotify.com/show/6e1Hu3JzBxBqyXfMpXVRoS" target="_blank" rel="noopener" class="content__pod-trailer">Watch Trailer</a>
          </div>

        </div>
        <div class="content__home-bar content__home-bar--light"></div>
      </div>
    </div>

    <!-- Phone 3: YouTube -->
    <div class="content__mockup" data-phone="2">
      <a class="content__desktop-pill" href="https://www.youtube.com/@DrCuterus" target="_blank" rel="noopener">YouTube</a>
      <div class="content__frame">
        <div class="content__island content__island--dark"></div>
        <div class="content__screen content__screen--yt">

          <div class="content__profile">
            <div class="content__avatar">
              <img
                src="/images/content-youtube.jpg"
                alt="Dr. Tanaya Narendra YouTube"
                class="content__avatar-img"
              />
            </div>
            <div class="content__profile-text">
              <span class="content__profile-name">Dr. Tanaya Narendra</span>
              <span class="content__profile-handle">@dr_cuterus</span>
            </div>
          </div>

          <p class="content__bio">Made for sharing 100% Science with 0% Sharam.</p>

          <div class="content__stats content__stats--yt">
            <!-- Stat 1: postcard reveals 1.9M subscribers -->
            <div class="content__stat content__stat--postcard">
              <div class="content__postcard">
                <b class="content__stat-num">1.9 M</b>
                <span class="content__stat-label">subscribers</span>
              </div>
              <img src="/doodles/ask your query no hover.svg" class="content__postcard-env" width="52" height="52" alt="" />
            </div>
            <!-- Stat 2: postcard reveals video count -->
            <div class="content__stat content__stat--postcard">
              <div class="content__postcard">
                <b class="content__stat-num">200+</b>
                <span class="content__stat-label">videos</span>
              </div>
              <img src="/doodles/ask your query no hover.svg" class="content__postcard-env" width="52" height="52" alt="" />
            </div>
            <!-- Stat 3: click to reveal card -->
            <div class="content__stat content__stat--ctr">
              <span class="content__stat-ctr-label">Click to reveal</span>
            </div>
          </div>

          <div class="content__vids">
            <a class="content__vid-thumb" href="https://youtu.be/3n2_HZ_JRTU?si=3Fx699a-dClP04YG" target="_blank" rel="noopener" aria-label="Watch video on YouTube">
              <img src="https://img.youtube.com/vi/3n2_HZ_JRTU/mqdefault.jpg" alt="Dr. Cuterus YouTube video" class="content__vid-img" />
              <span class="content__vid-play" aria-hidden="true">&#9654;</span>
            </a>
            <a class="content__vid-thumb content__vid-thumb--second" href="https://youtu.be/x3veBgcMzuU?si=CjSevBvW3ssvy_3B" target="_blank" rel="noopener" aria-label="Watch video on YouTube">
              <img src="https://img.youtube.com/vi/x3veBgcMzuU/mqdefault.jpg" alt="Dr. Cuterus YouTube video" class="content__vid-img" />
              <span class="content__vid-play" aria-hidden="true">&#9654;</span>
            </a>
          </div>
          <a href="https://www.youtube.com/@DrCuterus" target="_blank" rel="noopener" class="content__cta content__cta--yt-mobile">Subscribe Now</a>


        </div>
        <div class="content__home-bar content__home-bar--dark"></div>
      </div>
    </div>

  </div>

  <!-- Bottom strip -->
  <div class="content__strip">
    <p class="content__strip-sub content__strip-sub--hinglish">Building an audience across platforms. Shayad meri wajah se aapko apne phone ki volume kam karni padi ho,<br/>YOU SHOULD NOT!</p>
    <p class="content__strip-sub content__strip-sub--english">Building an audience across platforms. Possibly responsible for making you turn your volume down,<br/>YOU SHOULD NOT!</p>
    <h2 class="content__strip-heading">How you will find me while scrolling on your phone</h2>
  </div>

</section>

<style>
  /* ── SECTION ── */
  .content {
    background-color: var(--color-beige-500);
    padding-top: 80px;
    overflow: hidden;
    height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  /* ── PHONES ROW ── */
  .content__phones {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    gap: 82px;
    padding: 20px 40px 0;
    overflow: hidden;
    height: 500px;
  }

  /* ── SINGLE MOCKUP WRAPPER ── */
  .content__mockup {
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  /* ── DESKTOP PLATFORM PILL ── */
  .content__desktop-pill {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 0.9375rem;
    color: var(--color-brand-900);
    border: 1.5px solid var(--color-brand-900);
    border-radius: 999px;
    padding: 5px 18px;
    background: none;
    white-space: nowrap;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.15s ease;
  }

  .content__desktop-pill:hover {
    background: var(--color-yellow-500);
  }

  /* ── PHONE FRAME ── */
  .content__frame {
    width: 268px;
    border-radius: 40px;
    background: #1c1417;
    padding: 7px;
    box-shadow:
      inset 0 0 0 1px #3a3132,
      0 24px 64px rgba(28, 20, 23, 0.28);
    position: relative;
    display: flex;
    flex-direction: column;
  }

  /* Side buttons (volume left, power right) */
  .content__frame::before {
    content: '';
    position: absolute;
    left: -3px;
    top: 120px;
    width: 3px;
    height: 32px;
    background: #1c1417;
    border-radius: 2px 0 0 2px;
    box-shadow: 0 -46px 0 #1c1417, 0 48px 0 #1c1417;
  }

  .content__frame::after {
    content: '';
    position: absolute;
    right: -3px;
    top: 160px;
    width: 3px;
    height: 60px;
    background: #1c1417;
    border-radius: 0 2px 2px 0;
  }

  /* ── DYNAMIC ISLAND ── */
  .content__island {
    position: absolute;
    top: 20px;
    left: 50%;
    transform: translateX(-50%);
    width: 88px;
    height: 26px;
    background: #1c1417;
    border-radius: 13px;
    z-index: 10;
  }

  .content__island--dark {
    background: #1c1417;
  }

  /* ── SCREEN ── */
  .content__screen {
    border-radius: 33px;
    overflow: hidden;
    padding: 50px 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    min-height: 468px;
    position: relative;
  }

  .content__screen--ig {
    background: var(--color-brand-400);
    color: #fefefe;
  }

  /* Remove stat dividers on Instagram / YouTube screens */
  .content__screen--ig .content__stats,
  .content__screen--yt .content__stats {
    border-top: none;
    border-bottom: none;
  }

  /* Tighter vertical padding for YouTube stats so thumbnails fit */
  .content__screen--yt .content__stats {
    padding-top: 2px;
    padding-bottom: 2px;
  }

  /* ── POSTCARD REVEAL (YouTube stats) ── */
  .content__stat--postcard {
    position: relative;
    cursor: pointer;
    user-select: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .content__postcard {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%) translateY(0);
    background: #ffe07f;
    color: #1c1417;
    padding: 4px 8px;
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    align-items: center;
    z-index: 0;
    opacity: 0;
    pointer-events: none;
    white-space: nowrap;
    transition: transform 1.2s ease-out, opacity 0.8s ease;
  }

  .content__postcard-env {
    position: relative;
    z-index: 1;
    width: 52px;
    height: auto;
    display: block;
    transform: rotate(-6deg);
  }

  .content__stat--postcard.revealed .content__postcard {
    transform: translateX(-50%) translateY(calc(-100% - 6px));
    opacity: 1;
  }

  /* Heart reveal */
  .content__stat--reveal {
    position: relative;
    cursor: pointer;
    user-select: none;
  }

  .content__stat-heart {
    position: absolute;
    inset: -10px;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
    transition: opacity 0.35s ease, transform 0.35s ease;
  }

  .content__stat-heart img {
    width: 44px;
    height: 44px;
  }

  .content__stat--reveal.revealed .content__stat-heart {
    opacity: 0;
    transform: scale(1.6) rotate(20deg);
    pointer-events: none;
  }

  /* Click to reveal card (stat 3) */
  .content__stat--ctr {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .content__stat-ctr-label {
    background: var(--color-yellow-400, #ffe07f);
    color: #1c1417;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 400;
    padding: 4px 8px;
    line-height: 1.3;
    text-align: center;
  }

  .content__screen--podcast {
    background: #1e0f34;
    color: #fefefe;
    padding-left: 14px;
    padding-right: 14px;
    gap: 8px;
  }

  .content__screen--podcast .content__pod-art {
    width: 75%;
    align-self: center;
  }

  .content__screen--yt {
    background: var(--color-beige-500);
    color: #1c1417;
    gap: 6px;
  }

  /* ── HOME BAR ── */
  .content__home-bar {
    width: 100px;
    height: 4px;
    background: rgba(0, 0, 0, 0.3);
    border-radius: 2px;
    align-self: center;
    margin-top: 10px;
    margin-bottom: 4px;
    flex-shrink: 0;
  }

  .content__home-bar--light {
    background: rgba(255, 255, 255, 0.4);
  }

  .content__home-bar--dark {
    background: rgba(28, 20, 23, 0.25);
  }

  /* ── PROFILE ROW ── */
  .content__profile {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .content__avatar {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
  }

  .content__avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 15%;
    display: block;
  }

  .content__profile-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .content__profile-name {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.875rem;
    line-height: 1.2;
    color: inherit;
  }

  .content__profile-handle {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 0.75rem;
    color: inherit;
    opacity: 0.75;
  }

  /* ── BIO ── */
  .content__bio {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 0.68rem;
    line-height: 1.4;
    color: inherit;
    margin: 0;
  }

  /* ── STATS ROW ── */
  .content__stats {
    display: flex;
    justify-content: space-between;
    padding: 8px 0;
    border-top: 1px solid rgba(0, 0, 0, 0.12);
    border-bottom: 1px solid rgba(0, 0, 0, 0.12);
  }

  .content__screen--podcast .content__stats {
    border-color: rgba(255, 255, 255, 0.15);
  }

  .content__stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .content__stat-num {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.9375rem;
    color: inherit;
    line-height: 1;
  }

  .content__stat-label {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 0.6875rem;
    color: inherit;
    opacity: 0.7;
  }

  /* ── INSTAGRAM GRID (2-col thumbnails) ── */
  .content__grid2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4px;
    flex: 1;
  }

  .content__thumb {
    display: block;
    border-radius: 4px;
    overflow: hidden;
    aspect-ratio: 9 / 16;
    position: relative;
    text-decoration: none;
    background: #000;
  }

  .content__thumb-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .content__thumb-play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.12);
    color: white;
    font-size: 1.25rem;
    transition: background 0.15s ease;
  }

  .content__thumb:hover .content__thumb-play {
    background: rgba(0, 0, 0, 0.22);
  }

  /* ── PODCAST SCREEN (new layout) ── */
  .content__pod-art {
    width: 100%;
    aspect-ratio: 1;
    background: white;
    overflow: hidden;
    flex-shrink: 0;
  }

  .content__pod-art-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .content__pod-title {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1rem;
    color: white;
    text-align: center;
    margin: 0;
    line-height: 1.2;
  }

  .content__pod-artist {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.8);
    text-align: center;
    margin: 0;
  }

  .content__pod-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .content__pod-listen {
    background: var(--color-brand-400);
    color: white;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.9375rem;
    padding: 4px 16px;
    border-radius: 8px;
    text-decoration: none;
    display: inline-block;
    transition: background 0.15s ease;
  }

  .content__pod-listen:hover {
    background: var(--color-brand-500);
  }

  .content__pod-rating {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: white;
  }

  .content__pod-footer {
    margin-top: 8px;
    margin-bottom: -16px;
    background: #adadad;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 14px;
    gap: 8px;
  }

  .content__pod-avail {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    color: #0b0809;
    margin: 0;
    line-height: 1.2;
  }

  .content__pod-trailer {
    background: var(--color-yellow-500);
    color: #0b0809;
    font-family: var(--font-display);
    font-weight: 500;
    font-style: italic;
    font-size: 0.7rem;
    padding: 2px 4px;
    text-decoration: none;
    white-space: nowrap;
    letter-spacing: -0.03em;
    flex-shrink: 0;
  }

  /* ── YOUTUBE: hide bio to make room for thumbnails + button ── */
  .content__screen--yt .content__bio {
    display: none;
  }

  /* ── YOUTUBE VIDEO THUMBNAILS ── */
  .content__vids {
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: none;
  }

  .content__vid-thumb {
    display: block;
    position: relative;
    border-radius: 6px;
    overflow: hidden;
    flex: none;
    aspect-ratio: 16 / 9;
    text-decoration: none;
  }

  .content__vid-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .content__vid-play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.28);
    color: white;
    font-size: 1.5rem;
    transition: background 0.15s ease;
  }

  .content__vid-thumb:hover .content__vid-play {
    background: rgba(0, 0, 0, 0.45);
  }

  /* ── CTA BUTTON ── */
  .content__cta {
    display: block;
    width: fit-content;
    align-self: center;
    text-align: center;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 1rem;
    color: white;
    background-color: var(--color-brand-400);
    padding: 10px 16px;
    border-radius: 8px;
    text-decoration: none;
    margin-top: 8px;
    transition: background-color 0.15s ease;
  }

  .content__cta:hover {
    background-color: var(--color-brand-500, #5a2d7a);
  }

  .content__cta--white {
    background-color: var(--color-brand-400);
  }

  /* ── BOTTOM STRIP ── */
  .content__strip {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    padding: 16px 60px 24px;
    gap: 2px;
    border-top: 1px solid rgba(28, 20, 23, 0.1);
  }

  .content__strip-sub {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1rem;
    color: var(--color-brand-900);
    margin: 0;
    text-align: right;
    white-space: pre-line;
  }

  .content__strip-sub--english {
    display: none;
  }

  :global([data-lang="english"]) .content__strip-sub--english {
    display: block;
  }

  :global([data-lang="english"]) .content__strip-sub--hinglish {
    display: none;
  }

  .content__strip-heading {
    font-family: var(--font-display);
    font-weight: 500;
    font-style: italic;
    font-size: clamp(2rem, 3.1vw, 2.5rem);
    color: var(--color-brand-900);
    margin: 0;
    letter-spacing: -0.06em;
    line-height: 0.95;
    text-align: right;
  }

  /* ── MOBILE-ONLY ELEMENTS: always hidden except inside mobile breakpoint ── */
  .content__mobile-header,
  .content__mobile-controls {
    display: none !important;
  }

  /* ── DESKTOP-ONLY ELEMENTS: hidden on mobile ── */
  .content__desktop-pill {
    display: inline-block;
  }

  /* ── DESKTOP OVERRIDE ── */
  @media (min-width: 769px) {
    .content__mobile-header,
    .content__mobile-controls {
      display: none !important;
    }

    .content__cta--yt-mobile {
      display: none !important;
    }
  }

  /* ── TABLET (769–1024px) ── */
  @media (max-width: 1024px) and (min-width: 769px) {
    .content__phones {
      gap: clamp(16px, 3vw, 48px);
      padding: 32px 20px 0;
      height: 460px;
    }

    .content__frame {
      width: min(220px, 28vw);
      border-radius: 32px;
    }

    .content__strip {
      padding: 16px 24px 24px;
    }
  }

  /* ── MOBILE ── */
  @media (max-width: 768px) {
    .content {
      display: flex;
      flex-direction: column;
    }

    .content__desktop-pill {
      display: none !important;
    }

    /* Show mobile header at top */
    .content__mobile-header {
      display: flex !important;
      flex-direction: column;
      gap: -15px;
      padding: 4px 20px 6px;
    }

    .content__mobile-sub--english {
      display: none !important;
    }

    :global([data-lang="english"]) .content__mobile-sub--english {
      display: inline-block !important;
    }

    :global([data-lang="english"]) .content__mobile-sub--hinglish {
      display: none !important;
    }

    /* Subtitle in rotated yellow pill (matches Figma) */
    .content__mobile-sub {
      font-family: var(--font-sans);
      font-weight: 400;
      font-size: 1rem;
      color: var(--color-brand-900);
      background-color: var(--color-yellow-500);
      padding: 8px 14px;
      transform: rotate(-2deg);
      display: inline-block;
      align-self: flex-start;
      line-height: 1.4;
      max-width: 95%;
    }

    /* Large heading (matches Figma: bold italic purple, left-aligned) */
    .content__mobile-heading {
      font-family: var(--font-display);
      font-weight: 500;
      font-style: italic;
      font-size: clamp(2.5rem, 11vw, 3.25rem);
      color: var(--color-brand-400);
      letter-spacing: -0.06em;
      line-height: 0.95;
      margin: 0;
      text-align: left;
    }

    /* Show platform pill + nav arrows */
    .content__mobile-controls {
      display: flex !important;
      align-items: center;
      width: min(320px, calc(100vw - 48px));
      margin-left: auto;
      margin-right: auto;
      padding: 12px 0 8px;
    }

    /* Platform pill: oval border, no fill */
    .content__platform-pill {
      font-family: var(--font-sans);
      font-weight: 400;
      font-size: 0.9375rem;
      color: var(--color-brand-900);
      border: 1.5px solid var(--color-brand-900);
      border-radius: 999px;
      padding: 5px 18px;
      background: none;
    }

    /* Nav arrows: purple-bordered capsule with two arrow buttons */
    .content__mobile-nav {
      display: flex;
      align-items: center;
      gap: 4px;
      margin-left: auto;
    }

    .content__nav-btn {
      background: none;
      border: none;
      cursor: pointer;
      padding: 6px 14px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .content__nav-btn:first-child {
      border-right: none;
      padding-right: 1px;
    }

    .content__nav-arrow {
      width: 28px;
      height: auto;
      display: block;
    }

    .content__nav-arrow--left {
      transform: scaleX(-1);
    }

    /* Phones: always clips phone at bottom like desktop */
    .content__phones {
      height: min(calc(100svh - 260px), 440px);
      overflow: hidden;
      padding: 8px 20px 0;
      justify-content: center;
      align-items: flex-start;
    }

    .content__mockup {
      display: none;
    }

    .content__mockup--active {
      display: block;
    }

    /* Phone frame matches desktop width on mobile */
    .content__frame {
      width: min(268px, calc(100vw - 48px));
    }

    /* Instagram: remove flex:1 so grid doesn't stretch; cap thumbnail height */
    .content__grid2 {
      flex: none;
      gap: 16px;
    }

    .content__thumb {
      max-height: 160px;
    }

    .content__thumb:last-child {
      justify-self: end;
    }

    /* YouTube: hide second video, fix stretching container, show subscribe CTA */
    .content__vid-thumb--second {
      display: none;
    }

    .content__vids {
      flex: none;
      margin-top: 12px;
    }

    .content__vid-thumb {
      flex: none;
      aspect-ratio: 16 / 9;
    }

    .content__cta--yt-mobile {
      display: block;
      margin-top: 6px;
    }

    /* Hide desktop strip */
    .content__strip {
      display: none;
    }
  }
</style>

<script>
  const platforms = ['Instagram', 'The Dr. Cuterus Podcast', 'Youtube'];
  let current = 0;

  const pill = document.getElementById('content-platform-pill');
  const mockups = document.querySelectorAll<HTMLElement>('.content__mockup');

  function showSlide(index: number) {
    current = ((index % 3) + 3) % 3;
    if (pill) pill.textContent = platforms[current];
    mockups.forEach((m, i) => {
      m.classList.toggle('content__mockup--active', i === current);
    });
  }

  document.getElementById('content-prev')?.addEventListener('click', () => showSlide(current - 1));
  document.getElementById('content-next')?.addEventListener('click', () => showSlide(current + 1));

  // ── Instagram heart reveals: one-way click, auto-close after 5s ──
  document.querySelectorAll<HTMLElement>('.content__stat--reveal').forEach(el => {
    let timer: ReturnType<typeof setTimeout> | null = null;
    el.addEventListener('click', () => {
      if (el.classList.contains('revealed')) return;
      el.classList.add('revealed');
      timer = setTimeout(() => {
        el.classList.remove('revealed');
        timer = null;
      }, 5000);
    });
  });

  // ── YouTube postcard reveals: toggle click, auto-close after 5s ──
  document.querySelectorAll<HTMLElement>('.content__stat--postcard').forEach(el => {
    let timer: ReturnType<typeof setTimeout> | null = null;

    function close() {
      el.classList.remove('revealed');
      if (timer) { clearTimeout(timer); timer = null; }
    }

    el.addEventListener('click', () => {
      if (el.classList.contains('revealed')) {
        close();
      } else {
        el.classList.add('revealed');
        timer = setTimeout(close, 5000);
      }
    });
  });
</script>
