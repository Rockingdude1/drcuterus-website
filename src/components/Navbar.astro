---
const navLinks = [
  { label: "Home", href: "/" },
  { label: "Appointments", href: "/appointments" },
  { label: "Partnerships", href: "/partnerships" },
];

const rawPath = Astro.url.pathname;
const currentPath = rawPath === '/' ? '/' : rawPath.replace(/\/$/, '');
---

<header class="navbar">
  <a href="/" class="navbar__logo">Dr. Cuterus</a>

  <!-- Desktop nav -->
  <nav class="navbar__nav">
    {navLinks.map((link) => (
      <a
        href={link.href}
        class={`navbar__link ${currentPath === link.href ? "navbar__link--active" : ""}`}
      >
        {link.label}
      </a>
    ))}
  </nav>

  <!-- Right group: CTA + lang toggle (desktop) / menu toggle (mobile) -->
  <div class="navbar__right">
    <a href="https://mail.google.com/mail/?view=cm&to=drcuterus@gmail.com" target="_blank" rel="noopener" class="btn-primary navbar__cta">Work With Me</a>
    <button class="lang-toggle" id="desktop-lang-toggle" aria-label="Toggle language">Aa</button>
    <button class="navbar__toggle" id="mobile-toggle" aria-label="Open menu" aria-expanded="false">Menu</button>
  </div>
</header>

<!-- Mobile full-page overlay -->
<div class="mobile-menu" id="mobile-menu">
  <nav class="mobile-menu__nav">
    {navLinks.map((link) => (
      <a
        href={link.href}
        class={`mobile-menu__link ${currentPath === link.href ? "mobile-menu__link--active" : ""}`}
      >
        {link.label}
      </a>
    ))}
    <a href="https://mail.google.com/mail/?view=cm&to=drcuterus@gmail.com" target="_blank" rel="noopener" class="btn-primary mobile-menu__cta">Work With Me</a>
  </nav>
</div>

<style>
  /* ── NAVBAR BAR ── */
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 300;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 0 60px;
    height: 80px;
    background: rgba(247, 240, 224, 0.1);
    backdrop-filter: blur(100px);
    -webkit-backdrop-filter: blur(100px);
    border-bottom: 2px solid rgba(28, 20, 23, 0.6);
  }

  .navbar__logo {
    font-family: var(--font-display);
    font-weight: 500;
    font-style: italic;
    font-size: 1.875rem;
    color: var(--color-black);
    text-decoration: none;
    white-space: nowrap;
  }

  /* ── RIGHT GROUP: CTA + lang toggle (desktop) / menu toggle (mobile) ── */
  .navbar__right {
    display: flex;
    align-items: center;
    gap: 16px;
    justify-self: end;
  }

  /* ── DESKTOP NAV ── */
  .navbar__nav {
    display: flex;
    align-items: center;
    gap: 1.7rem;
  }

  .navbar__link {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 300;
    color: var(--color-black);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    transition: color 0.2s ease;
    position: relative;
  }

  .navbar__link:hover {
    color: var(--color-brand-400);
  }

  .navbar__link--active {
    font-weight: 700;
  }

  .navbar__link--active::after {
    content: "";
    position: absolute;
    left: -12px;
    right: -12px;
    top: 50%;
    transform: translateY(-50%);
    height: 28px;
    background-color: var(--color-brand-100);
    border-radius: 20px;
    z-index: -1;
  }

  .navbar__cta {
    flex-shrink: 0;
    font-size: 1rem;
    background-color: var(--color-brand-300) !important;
  }

  .navbar__cta:hover {
    background-color: var(--color-brand-500) !important;
  }

  /* ── LANGUAGE TOGGLE (desktop) ── */
  .lang-toggle {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background-color: var(--color-yellow-500);
    border: none;
    cursor: pointer;
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-brand-900);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: transform 0.15s ease;
  }

  .lang-toggle:hover {
    transform: scale(1.08);
  }

  /* ── MOBILE TOGGLE ── */
  .navbar__toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-black);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    flex-shrink: 0;
    line-height: 1;
    transition: background-color 0.2s ease;
  }

  /* When nav is open, toggle becomes the yellow lang button */
  .navbar__toggle.is-lang-toggle {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background-color: var(--color-yellow-500);
    color: var(--color-brand-900);
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: 0;
    text-transform: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ── MOBILE OVERLAY (hidden on desktop) ── */
  .mobile-menu {
    display: none;
  }

  /* ── TABLET (769–1024px) ── */
  @media (max-width: 1024px) and (min-width: 769px) {
    .navbar {
      padding: 0 32px;
    }

    .navbar__nav {
      gap: 1rem;
    }

    .navbar__logo {
      font-size: 1.5rem;
    }

    .navbar__cta {
      font-size: 0.875rem;
      padding: 8px 14px;
    }
  }

  /* ── MOBILE ── */
  @media (max-width: 768px) {
    .navbar {
      padding: 0 20px;
      height: 56px;
      grid-template-columns: 1fr auto;
      background: rgba(247, 240, 224, 0.97);
    }

    .navbar__logo {
      font-size: 1.5rem;
    }

    /* Hide desktop nav (center column collapses) */
    .navbar__nav {
      display: none;
    }

    /* Hide desktop-only controls */
    .lang-toggle {
      display: none;
    }

    .navbar__cta {
      display: none;
    }

    /* Show mobile toggle */
    .navbar__toggle {
      display: flex;
    }

    /* Full-page overlay, slides in from the right */
    .mobile-menu {
      display: block;
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 200;
      background: var(--color-beige-500);
      overflow-y: auto;
      transform: translateX(100%);
      transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .mobile-menu.is-open {
      transform: translateX(0);
    }

    .mobile-menu__nav {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
      padding: 100px 32px 40px;
    }

    .mobile-menu__link {
      font-family: var(--font-sans);
      font-size: 1.125rem;
      font-weight: 300;
      color: var(--color-black);
      text-decoration: none;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      transition: color 0.2s ease;
      position: relative;
    }

    .mobile-menu__link:hover {
      color: var(--color-brand-400);
    }

    .mobile-menu__link--active {
      font-weight: 700;
    }

    .mobile-menu__link--active::after {
      content: "";
      position: absolute;
      left: -12px;
      right: -12px;
      top: 50%;
      transform: translateY(-50%);
      height: 28px;
      background-color: var(--color-brand-100);
      border-radius: 15px;
      z-index: -1;
    }

    .mobile-menu__cta {
      font-size: 1rem;
      margin-top: 8px;
    }
  }
</style>

<script>
  // ── LANGUAGE STATE ──
  const LANG_KEY = 'dr-cuterus-lang';

  function getSavedLang(): string {
    return localStorage.getItem(LANG_KEY) || 'hinglish';
  }

  function setLang(lang: string) {
    document.documentElement.setAttribute('data-lang', lang);
    localStorage.setItem(LANG_KEY, lang);
  }

  function getLangButtonText(lang: string): string {
    // Hinglish mode → show "Aa" (click to go English)
    // English mode  → show "Aआ" (click to go Hinglish)
    return lang === 'hinglish' ? 'Aa' : 'Aआ';
  }

  function updateToggleLabels(lang: string) {
    const text = getLangButtonText(lang);
    if (desktopToggle) desktopToggle.textContent = text;
    // Mobile toggle only shows lang text when nav is open
    if (mobileToggle && mobileToggle.classList.contains('is-lang-toggle')) {
      mobileToggle.textContent = text;
    }
  }

  // Init language on load
  const initLang = getSavedLang();
  setLang(initLang);

  const desktopToggle = document.getElementById('desktop-lang-toggle') as HTMLButtonElement;
  const mobileToggle = document.getElementById('mobile-toggle') as HTMLButtonElement;
  const menu = document.getElementById('mobile-menu') as HTMLDivElement;

  // Set initial toggle labels
  updateToggleLabels(initLang);

  // ── DESKTOP LANG TOGGLE ──
  desktopToggle?.addEventListener('click', () => {
    const current = document.documentElement.getAttribute('data-lang') || 'hinglish';
    const next = current === 'hinglish' ? 'english' : 'hinglish';
    setLang(next);
    updateToggleLabels(next);
  });

  // ── MOBILE NAV OPEN / CLOSE ──
  function openMenu() {
    menu.classList.add('is-open');
    mobileToggle.setAttribute('aria-expanded', 'true');
    mobileToggle.classList.add('is-lang-toggle');
    const lang = document.documentElement.getAttribute('data-lang') || 'hinglish';
    mobileToggle.textContent = getLangButtonText(lang);
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menu.classList.remove('is-open');
    mobileToggle.setAttribute('aria-expanded', 'false');
    mobileToggle.classList.remove('is-lang-toggle');
    mobileToggle.textContent = 'Menu';
    document.body.style.overflow = '';
  }

  mobileToggle?.addEventListener('click', () => {
    if (menu.classList.contains('is-open')) {
      // Nav is open — this button is now the lang toggle
      const current = document.documentElement.getAttribute('data-lang') || 'hinglish';
      const next = current === 'hinglish' ? 'english' : 'hinglish';
      setLang(next);
      closeMenu();
    } else {
      openMenu();
    }
  });

  // Close menu when a nav link is tapped
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMenu);
  });
</script>
