---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import clinicImage from '../assets/images/clinic-image.png';

// Replace these with real Google reviews from her Maps listing
const reviews = [
  {
    text: "Dr. Tanaya is incredibly knowledgeable and makes you feel completely at ease. She addressed all my questions about PCOS and menstrual health without any judgment whatsoever.",
    name: "Priya M."
  },
  {
    text: "Best consultation I've ever had. She explained everything so clearly — I finally understood what was happening with my body. No question felt too silly or awkward.",
    name: "Aakriti S."
  },
  {
    text: "I was so nervous before my appointment but Dr. Tanaya was so warm and reassuring. She took her time and genuinely listened. Absolutely recommend her to everyone.",
    name: "Neha R."
  },
  {
    text: "Had concerns about fertility and egg health — she addressed everything thoroughly without making me feel scared. I left feeling informed and hopeful.",
    name: "Divya K."
  },
  {
    text: "The consultation was completely confidential and judgment-free, exactly as promised. Dr. Tanaya is the kind of doctor everyone deserves to have access to.",
    name: "Riya P."
  }
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Appointments - Dr. Cuterus</title>
    <meta name="description" content="Book an online consultation with Dr. Tanaya Narendra - confidential, judgment-free." />
    <meta property="og:title" content="Appointments - Dr. Cuterus" />
    <meta property="og:description" content="Book an online consultation with Dr. Tanaya Narendra - confidential, judgment-free." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://drcuterus.com/appointments" />
    <meta property="og:image" content="https://drcuterus.com/og-image.png" />
    <meta property="og:image:alt" content="Dr. Tanaya Narendra - Dr. Cuterus" />
  </head>
  <body>
    <Navbar />

    <!-- SECTION 1: Hero with floating tags -->
    <div class="appt-hero-outer">
      <div class="appt-hero-top">
        <p class="appt-hero__label">Online consultations available</p>
        <h1 class="appt-hero__heading">Does any of these<br/> sound like you?</h1>
      </div>

      <!-- Purple grid tag cloud — full viewport width -->
      <div class="appt-hero__tag-cloud">
        <div class="appt-tag appt-tag--yellow appt-tag--p1">Irregular or painful periods</div>
        <div class="appt-tag appt-tag--purple-dark appt-tag--p2">PCOS symptoms</div>
        <div class="appt-tag appt-tag--beige appt-tag--p3">HPV, STIs?<br/>Don't know where to start.</div>
        <div class="appt-tag appt-tag--yellow-light appt-tag--p4">Questions about fertility<br/>or egg health</div>
        <div class="appt-tag appt-tag--purple-dark appt-tag--p5">Confused about<br/>contraception options</div>
        <div class="appt-tag appt-tag--purple-dark appt-tag--p6">Want a second opinion<br/>without judgment</div>
      </div>

      <div class="appt-hero-bottom">
        <p class="appt-hero__tagline">For all these and more, you deserve a <br/>doctor who actually listens.</p>
        <a href="#" class="btn-primary appt-hero__cta">Book Via WhatsApp →</a>
        <p class="appt-hero__disclaimer">*All consultations are confidential and judgment-free.</p>
      </div>
    </div>

    <!-- SECTION 2: Doctor + booking -->
    <div class="appt-book-outer">
      <section class="appt-book">
        <div class="appt-book__photo-wrap">
          <Image
            src={clinicImage}
            alt="Dr. Tanaya Narendra in her clinic"
            class="appt-book__photo"
            widths={[400, 700]}
            sizes="348px"
          />
        </div>

        <div class="appt-book__content">
          <h2 class="appt-book__heading">Book A Private Consultation</h2>

          <div class="appt-book__pills">
            <span class="appt-pill">MBBS, MSc (Oxon), FRSPH</span>
            <span class="appt-pill">Medical Doctor &amp; Embryologist</span>
            <span class="appt-pill">Fellow, Royal Society for Public Health</span>
            <span class="appt-pill">10+ Years In Reproductive Health</span>
          </div>

          <!-- Google review carousel -->
          <div class="appt-review-card">
            <div class="appt-review__stars">★★★★★</div>
            <p class="appt-review__text" id="review-text"></p>
            <div class="appt-review__footer">
              <span class="appt-review__name" id="review-name"></span>
              <div class="appt-review__nav">
                <button class="appt-review__nav-btn" id="review-prev" aria-label="Previous review">
                  <img src="/doodles/arrow-content.svg" class="appt-review__arrow appt-review__arrow--left" alt="" />
                </button>
                <button class="appt-review__nav-btn" id="review-next" aria-label="Next review">
                  <img src="/doodles/arrow-content.svg" class="appt-review__arrow" alt="" />
                </button>
              </div>
            </div>
          </div>

          <div class="appt-book__ctas">
            <a href="#" class="btn-primary appt-book__cta">Book Via WhatsApp →</a>
            <a href="#" class="btn-outline appt-book__cta appt-book__cta--review">Add a Review →</a>
          </div>
        </div>
      </section>
    </div>

    <!-- Footer -->
    <div class="appt-footer">
      <p class="appt-footer__heading">Found something you liked? Let's talk.</p>
      <p class="appt-footer__sub">For collabs, speaking, and partnerships or just to say hi!</p>
      <a href="https://mail.google.com/mail/?view=cm&to=drcuterus@gmail.com" target="_blank" rel="noopener" class="btn-primary">Work with Me</a>
    </div>
    <Footer />
  </body>
</html>

<script define:vars={{ reviews }}>
  let currentIndex = 0;

  function updateReview() {
    const textEl = document.getElementById('review-text');
    const nameEl = document.getElementById('review-name');
    if (textEl) textEl.textContent = reviews[currentIndex].text;
    if (nameEl) nameEl.textContent = reviews[currentIndex].name;
  }

  const prevBtn = document.getElementById('review-prev');
  const nextBtn = document.getElementById('review-next');

  if (prevBtn) {
    prevBtn.addEventListener('click', () => {
      currentIndex = (currentIndex - 1 + reviews.length) % reviews.length;
      updateReview();
    });
  }

  if (nextBtn) {
    nextBtn.addEventListener('click', () => {
      currentIndex = (currentIndex + 1) % reviews.length;
      updateReview();
    });
  }

  updateReview();
</script>

<style>
  body {
    background-color: var(--color-beige-500);
    margin: 0;
    padding: 0;
  }

  /* ── SECTION 1: HERO ── */
  .appt-hero-outer {
    padding-top: 80px;
  }

  .appt-hero-top,
  .appt-hero-bottom {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 60px;
  }

  .appt-hero-bottom {
    padding-bottom: 10px;
  }

  .appt-hero__label {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1rem;
    color: rgba(28, 20, 23, 0.6);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 24px 0 8px;
    text-align: center;
  }

  .appt-hero__heading {
    font-family: var(--font-display);
    font-weight: 500;
    font-style: italic;
    font-size: clamp(2rem, 3.75vw, 3rem);
    color: var(--color-brand-400);
    letter-spacing: -0.06em;
    line-height: 0.95;
    margin: 0 0 16px;
    text-align: center;
  }

  /* Tag cloud: purple grid bg */
  .appt-hero__tag-cloud {
    width: 100%;
    height: 283px;
    background-color: var(--color-brand-100);
    background-image:
      linear-gradient(rgba(110, 57, 151, 0.15) 1px, transparent 1px),
      linear-gradient(90deg, rgba(110, 57, 151, 0.15) 1px, transparent 1px);
    background-size: 32px 32px;
    position: relative;
    flex-shrink: 0;
  }

  /* Individual floating tags */
  .appt-tag {
    position: absolute;
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: clamp(1rem, 1.6vw, 1.25rem);
    padding: 8px 16px;
    border-radius: 8px;
    border: 1px solid var(--color-black);
    text-align: center;
    line-height: 1.1;
    white-space: nowrap;
  }

  .appt-tag--yellow {
    background-color: var(--color-yellow-500);
    color: var(--color-black);
  }

  .appt-tag--yellow-light {
    background-color: #ffe07f;
    color: var(--color-black);
  }

  .appt-tag--purple-dark {
    background-color: var(--color-brand-400);
    color: var(--color-brand-50);
  }

  .appt-tag--beige {
    background-color: var(--color-beige-500);
    color: var(--color-black);
  }

  /* Desktop positions */
  .appt-tag--p1 { left: 25%;   top: 20%; transform: rotate(-5.77deg); }
  .appt-tag--p2 { left: 26%; top: 40%; transform: rotate(1.26deg);  }
  .appt-tag--p3 { left: 40.9%; top: 28%; }
  .appt-tag--p4 { left: 50.7%; top: 53%; transform: rotate(1.09deg);  }
  .appt-tag--p5 { left: 32%;   top: 56%; transform: rotate(-4.06deg); }
  .appt-tag--p6 { left: 58.3%; top: 7%;  transform: rotate(-2.03deg); }

  .appt-hero__tagline {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1.5rem;
    color: var(--color-brand-900);
    margin: 28px 0 20px;
    text-align: center;
  }

  .appt-hero__cta {
    font-size: 1.5rem;
    padding: 8px 20px;
    background-color: var(--color-brand-300);
  }

  .appt-hero__cta:hover {
    background-color: var(--color-brand-900);
  }

  .appt-hero__disclaimer {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 0.68rem;
    color: var(--color-black);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 12px 0 0;
    text-align: center;
  }

  /* ── SECTION 2: BOOKING ── */
  .appt-book-outer {
    background-color: var(--color-yellow-400);
  }

  .appt-book {
    min-height: 599px;
    display: grid;
    grid-template-columns: 348px 1fr;
    gap: 60px;
    padding: 74px 109px 60px;
    max-width: 1280px;
    margin: 0 auto;
    box-sizing: border-box;
  }

  .appt-book__photo-wrap {
    position: relative;
    align-self: center;
  }

  .appt-book__photo {
    width: 100%;
    height: 452px;
    object-fit: cover;
    border-radius: 16px;
    border: 2px solid var(--color-yellow-500);
    box-shadow: 0px 0px 6px 2px rgba(0,0,0,0.25);
    display: block;
  }

  .appt-book__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 20px;
  }

  .appt-book__heading {
    font-family: var(--font-display);
    font-weight: 500;
    font-style: italic;
    font-size: clamp(2rem, 3.75vw, 3rem);
    color: var(--color-brand-400);
    margin: 0;
    letter-spacing: -0.06em;
    line-height: 0.95;
  }

  /* Credential pills */
  .appt-book__pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .appt-pill {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.9rem;
    color: var(--color-brand-400);
    background-color: var(--color-brand-50);
    border: 1px solid var(--color-brand-200);
    border-radius: 9999px;
    padding: 5px 14px;
    white-space: nowrap;
    line-height: 1.4;
  }

  /* Review card */
  .appt-review-card {
    background: var(--color-white);
    border: 2px solid var(--color-black);
    box-shadow: 1px 2px 6px 2px rgba(0, 0, 0, 0.25);
    padding: 18px 24px 16px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    min-height: 180px;
  }

  .appt-review__stars {
    font-size: 1.75rem;
    color: var(--color-yellow-500);
    text-align: center;
    letter-spacing: 4px;
    flex-shrink: 0;
  }

  .appt-review__text {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1rem;
    color: var(--color-brand-900);
    margin: 0;
    line-height: 1.55;
    flex: 1;
  }

  .appt-review__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .appt-review__name {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-brand-900);
  }

  .appt-review__nav {
    display: flex;
    gap: 4px;
    flex-shrink: 0;
  }

  .appt-review__nav-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    transition: opacity 0.15s ease;
  }

  .appt-review__nav-btn:hover {
    opacity: 0.75;
  }

  .appt-review__arrow {
    width: 27px;
    height: auto;
    display: block;
  }

  .appt-review__arrow--left {
    transform: scaleX(-1);
  }

  .appt-book__cta--review {
    background-color: var(--color-white);
    border-color: var(--color-brand-900);
  }

  .appt-book__cta--review:hover {
    background-color: var(--color-brand-50);
  }

  /* CTA buttons row */
  .appt-book__ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: center;
  }

  .appt-book__cta {
    font-size: 1.25rem;
    padding: 10px 20px;
  }

  /* ── FOOTER ── */
  .appt-footer {
    background-color: var(--color-brand-100);
    background-image:
      linear-gradient(rgba(110, 57, 151, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(110, 57, 151, 0.08) 1px, transparent 1px);
    background-size: 40px 40px;
    height: 200px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
  }

  .appt-footer > .btn-primary {
    margin-top: -4px;
  }

  .appt-footer__heading {
    font-family: var(--font-display);
    font-weight: 500;
    font-style: italic;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    color: var(--color-brand-900);
    margin: 0;
    letter-spacing: -0.06em;
    line-height: 0.95;
    text-align: center;
  }

  .appt-footer__sub {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1rem;
    color: var(--color-brand-900);
    margin: 0;
    text-align: center;
  }

  /* ── TABLET (769–1024px) ── */
  @media (max-width: 1024px) and (min-width: 769px) {
    .appt-hero-top,
    .appt-hero-bottom {
      padding: 0 32px;
    }

    .appt-book {
      grid-template-columns: 1fr 1fr;
      padding: 48px 60px;
      gap: 40px;
    }

    .appt-book__photo {
      height: 360px;
    }
  }

  /* ── MOBILE ── */
  @media (max-width: 768px) {
    /* Tag cloud: taller to fit stacked mobile layout */
    .appt-hero__tag-cloud {
      height: 298px;
    }

    .appt-tag {
      font-size: 0.875rem;
      padding: 6px 12px;
    }

    /* Mobile positions from Figma (percentage left for responsiveness) */
    .appt-tag--p1 { left: 5%;   top: 26px;  transform: rotate(-5.77deg); }
    .appt-tag--p2 { left: 50%;  top: 65px;  transform: rotate(1.26deg);  }
    .appt-tag--p3 { left: 36%;  top: 152px; transform: rotate(-0.26deg); }
    .appt-tag--p4 { left: 3%;   top: 96px;  transform: rotate(1.09deg);  }
    .appt-tag--p5 { left: 10%;  top: 210px; transform: rotate(-4.06deg); }
    .appt-tag--p6 { display: none; }

    .appt-hero__tagline {
      font-size: 1rem;
      margin: 16px 0 16px;
    }

    .appt-hero__cta {
      font-size: 1rem;
      padding: 8px 20px;
    }

    .appt-hero-top,
    .appt-hero-bottom {
      padding: 0 20px;
    }

    .appt-book {
      grid-template-columns: 1fr;
      padding: 40px 24px;
      gap: 32px;
    }

    .appt-book__photo {
      height: 390px;
    }

    .appt-pill {
      font-size: 0.85rem;
    }

    .appt-review-card {
      min-height: 220px;
    }

    .appt-book__ctas {
      flex-direction: column;
      align-items: stretch;
    }

    .appt-book__cta {
      font-size: 1rem;
      text-align: center;
    }
  }
</style>
