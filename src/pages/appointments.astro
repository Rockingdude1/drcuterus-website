---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import clinicImage from '../assets/images/clinic-image.png';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Appointments — Dr. Cuterus</title>
    <meta name="description" content="Book an online consultation with Dr. Tanaya Narendra — confidential, judgment-free." />
  </head>
  <body>
    <Navbar />

    <!-- SECTION 1: Hero with floating tags -->
    <div class="appt-hero-outer">
      <div class="appt-hero-top">
        <p class="appt-hero__label">Online consultations available</p>
        <h1 class="appt-hero__heading">Does any of these<br/> sound like you?</h1>
      </div>

      <!-- Purple grid tag cloud — full viewport width -->
      <div class="appt-hero__tag-cloud">
        <div class="appt-tag appt-tag--yellow appt-tag--p1">Irregular or painful periods</div>
        <div class="appt-tag appt-tag--purple-dark appt-tag--p2">PCOS symptoms</div>
        <div class="appt-tag appt-tag--beige appt-tag--p3">HPV, STIs?<br/>Don't know where to start.</div>
        <div class="appt-tag appt-tag--yellow-light appt-tag--p4">Questions about fertility<br/>or egg health</div>
        <div class="appt-tag appt-tag--purple-dark appt-tag--p5">Confused about<br/>contraception options</div>
        <div class="appt-tag appt-tag--purple-dark appt-tag--p6">Want a second opinion<br/>without judgment</div>
      </div>

      <div class="appt-hero-bottom">
        <p class="appt-hero__tagline">For all these and more, you deserve a <br/>doctor who actually listens.</p>
        <a href="#" class="btn-primary appt-hero__cta">Book Via WhatsApp →</a>
        <p class="appt-hero__disclaimer">*All consultations are confidential and judgment-free.</p>
      </div>
    </div>

    <!-- SECTION 2: Doctor + booking -->
    <div class="appt-book-outer">
    <section class="appt-book">
      <div class="appt-book__photo-wrap">
        <Image
          src={clinicImage}
          alt="Dr. Tanaya Narendra in her clinic"
          class="appt-book__photo"
          widths={[400, 700]}
          sizes="348px"
        />
      </div>

      <div class="appt-book__content">
        <h2 class="appt-book__heading">Get One on One Consultations</h2>

        <p class="appt-book__bio">
I, Dr. Tanaya Narendra, am an Oxford-trained embryologist and registered medical doctor with over a decade of experience in reproductive and sexual health. I have worked across India and the UK, and bring both clinical rigour and genuine warmth to every consultation. My expertise spans menstrual health, fertility, contraception, STIs, and sexual wellness.
        </p>

        <a href="#" class="btn-primary appt-book__cta">Book Via WhatsApp →</a>
      </div>
    </section>
    </div>

    <!-- Footer -->
    <div class="appt-footer">
      <p class="appt-footer__heading">Found something you liked? Let's talk.</p>
      <p class="appt-footer__sub">For collabs, speaking, and partnerships — or just to say hi!</p>
      <a href="https://mail.google.com/mail/?view=cm&to=drcuterus@gmail.com" target="_blank" rel="noopener" class="btn-primary">Work with Me</a>
    </div>
    <Footer />
  </body>
</html>

<style>
  body {
    background-color: var(--color-beige-500);
    margin: 0;
    padding: 0;
  }

  /* ── SECTION 1: HERO ── */
  .appt-hero-outer {
    padding-top: 80px;
  }

  .appt-hero-top,
  .appt-hero-bottom {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 60px;
  }

  .appt-hero-bottom {
    padding-bottom: 40px;
  }

  .appt-hero__label {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1rem;
    color: rgba(28, 20, 23, 0.6);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 24px 0 8px;
    text-align: center;
  }

  .appt-hero__heading {
    font-family: var(--font-display);
    font-weight: 500;
    font-style: italic;
    font-size: clamp(2rem, 3.75vw, 3rem);
    color: var(--color-brand-400);
    letter-spacing: -0.06em;
    line-height: 0.95;
    margin: 0 0 16px;
    text-align: center;
  }

  /* Tag cloud: purple grid bg */
  .appt-hero__tag-cloud {
    width: 100%;
    height: 283px;
    background-color: var(--color-brand-100);
    background-image:
      linear-gradient(rgba(110, 57, 151, 0.15) 1px, transparent 1px),
      linear-gradient(90deg, rgba(110, 57, 151, 0.15) 1px, transparent 1px);
    background-size: 32px 32px;
    position: relative;
    flex-shrink: 0;
  }

  /* Individual floating tags */
  .appt-tag {
    position: absolute;
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: clamp(1rem, 1.6vw, 1.25rem);
    padding: 8px 16px;
    border-radius: 8px;
    border: 1px solid var(--color-black);
    text-align: center;
    line-height: 1.1;
    white-space: nowrap;
  }

  .appt-tag--yellow {
    background-color: var(--color-yellow-500);
    color: var(--color-black);
  }

  .appt-tag--yellow-light {
    background-color: #ffe07f;
    color: var(--color-black);
  }

  .appt-tag--purple-dark {
    background-color: var(--color-brand-400);
    color: var(--color-brand-50);
  }

  .appt-tag--beige {
    background-color: var(--color-beige-500);
    color: var(--color-black);
  }

  /* Desktop positions (moved from inline styles) */
  .appt-tag--p1 { left: 25%;   top: 20%; transform: rotate(-5.77deg); }
  .appt-tag--p2 { left: 26%; top: 40%; transform: rotate(1.26deg);  }
  .appt-tag--p3 { left: 40.9%; top: 28%; }
  .appt-tag--p4 { left: 50.7%; top: 53%; transform: rotate(1.09deg);  }
  .appt-tag--p5 { left: 32%;   top: 56%; transform: rotate(-4.06deg); }
  .appt-tag--p6 { left: 58.3%; top: 7%;  transform: rotate(-2.03deg); }

  .appt-hero__tagline {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1.5rem;
    color: var(--color-brand-900);
    margin: 28px 0 20px;
    text-align: center;
  }

  .appt-hero__cta {
    font-size: 1.5rem;
    padding: 8px 20px;
    background-color: var(--color-brand-300);
  }

  .appt-hero__cta:hover {
    background-color: var(--color-brand-900);
  }

  .appt-hero__disclaimer {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 0.68rem;
    color: var(--color-black);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 12px 0 0;
    text-align: center;
  }

  /* ── SECTION 2: BOOKING ── */
  .appt-book-outer {
    background-color: var(--color-yellow-400);
  }

  .appt-book {
    min-height: 599px;
    display: grid;
    grid-template-columns: 348px 1fr;
    gap: 60px;
    padding: 74px 109px 60px;
    max-width: 1280px;
    margin: 0 auto;
    box-sizing: border-box;
  }

  .appt-book__photo-wrap {
    position: relative;
    align-self: center;
  }

  .appt-book__photo {
    width: 100%;
    height: 452px;
    object-fit: cover;
    border-radius: 16px;
    border: 2px solid var(--color-yellow-500);
    box-shadow: 0px 0px 6px 2px rgba(0,0,0,0.25);
    display: block;
  }

  .appt-book__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 24px;
  }

  .appt-book__heading {
    font-family: var(--font-display);
    font-weight: 500;
    font-style: italic;
    font-size: clamp(2rem, 2.8vw, 2.75rem);
    color: var(--color-brand-900);
    margin: 0;
    letter-spacing: -0.06em;
    line-height: 0.95;
  }

  .appt-book__bio {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1.5rem;
    color: var(--color-brand-900);
    margin: 0;
    line-height: 1.5;
  }

  .appt-book__cta {
    font-size: 1.5rem;
    padding: 8px 20px;
    align-self: flex-start;
    background-color: var(--color-brand-300);
  }

  .appt-book__cta:hover {
    background-color: var(--color-brand-900);
  }

  /* ── FOOTER ── */
  .appt-footer {
    background-color: var(--color-brand-100);
    background-image:
      linear-gradient(rgba(110, 57, 151, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(110, 57, 151, 0.08) 1px, transparent 1px);
    background-size: 40px 40px;
    height: 266px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
  }

  .appt-footer > .btn-primary {
    margin-top: -4px;
  }

  .appt-footer__heading {
    font-family: var(--font-display);
    font-weight: 500;
    font-style: italic;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    color: var(--color-brand-900);
    margin: 0;
    letter-spacing: -0.06em;
    line-height: 0.95;
    text-align: center;
  }

  .appt-footer__sub {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1rem;
    color: var(--color-brand-900);
    margin: 0;
    text-align: center;
  }

  /* ── TABLET (769–1024px) ── */
  @media (max-width: 1024px) and (min-width: 769px) {
    .appt-hero-top,
    .appt-hero-bottom {
      padding: 0 32px;
    }

    .appt-book {
      grid-template-columns: 1fr 1fr;
      padding: 48px 60px;
      gap: 40px;
    }

    .appt-book__photo {
      height: 360px;
    }
  }

  /* ── MOBILE ── */
  @media (max-width: 768px) {
    /* Tag cloud: taller to fit stacked mobile layout */
    .appt-hero__tag-cloud {
      height: 298px;
    }

    .appt-tag {
      font-size: 0.875rem;
      padding: 6px 12px;
    }

    /* Mobile positions from Figma (pixel-based for 390px frame) */
    .appt-tag--p1 { left: 40px;  top: 40px;  transform: rotate(-5.77deg); }
    .appt-tag--p2 { left: 180px; top: 65px;  transform: rotate(1.26deg);  }
    .appt-tag--p3 { left: 143px; top: 138px; transform: none; }
    .appt-tag--p4 { left: 30px;  top: 90px;  transform: rotate(1.09deg);  }
    .appt-tag--p5 { left: 43px;  top: 190px; transform: rotate(-4.06deg); }
    .appt-tag--p6 { display: none; }

    .appt-hero__tagline {
      font-size: 1rem;
      margin: 16px 0 16px;
    }

    .appt-hero__cta {
      font-size: 1rem;
      padding: 8px 20px;
    }

    .appt-hero-top,
    .appt-hero-bottom {
      padding: 0 20px;
    }

    .appt-book {
      grid-template-columns: 1fr;
      padding: 40px 24px;
    }

    .appt-book__photo {
      height: 300px;
    }

    .appt-book__bio {
      font-size: 1.1rem;
    }

    .appt-book__cta {
      font-size: 1rem;
      padding: 8px 20px;
    }
  }
</style>
