---
import '../../styles/global.css';
import Navbar from '../../components/Navbar.astro';
import { posts, getPost } from '../../data/posts';

export function getStaticPaths() {
  return posts.map((post) => ({ params: { slug: post.slug } }));
}

const { slug } = Astro.params;
const post = getPost(slug);
if (!post) return Astro.redirect('/blog');

const related = posts.filter(p => p.slug !== post.slug).slice(0, 4);

const bodyHtml = post.body
  .split('\n\n')
  .map(p => `<p>${p.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')}</p>`)
  .join('');
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{post.question} - Dr. Cuterus</title>
    <meta name="description" content={post.excerpt} />
    <meta property="og:title" content={`${post.question} - Dr. Cuterus`} />
    <meta property="og:description" content={post.excerpt} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={`https://drcuterus.com/blog/${post.slug}`} />
    <meta property="og:image" content="https://drcuterus.com/og-image.png" />
    <meta property="og:image:alt" content="Dr. Tanaya Narendra - Dr. Cuterus" />
  </head>
  <body>
    <Navbar />

    <main class="post">

      <!-- Main content card -->
      <div class="post__card">
        <h1 class="post__question">{post.question}</h1>
        <div class="post__divider"></div>
        <div class="post__body" set:html={bodyHtml} />
      </div>

      <!-- Related blogs + mail row -->
      <div class="post__lower">
        <div class="post__related">
          <span class="post__related-label">Related Blogs</span>
          <ul class="post__related-list">
            {related.map(r => (
              <li>
                <a href={`/blog/${r.slug}`} class="post__related-link">{r.question}</a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CSS mail envelope -->
        <div class="post__mail">
          <div class="post__mail-body">
            <div class="post__mail-flap"></div>
          </div>
        </div>
      </div>
    </main>

    <!-- Footer -->
    <div class="blog-footer">
      <p class="blog-footer__heading">Found something you liked? Let's talk.</p>
      <p class="blog-footer__sub">For collabs, speaking, and partnerships or just to say hi!</p>
      <a href="https://mail.google.com/mail/?view=cm&to=drcuterus@gmail.com" target="_blank" rel="noopener" class="btn-primary">Work with Me</a>
    </div>
  </body>
</html>

<style>
  body {
    background-color: var(--color-beige-500);
    margin: 0;
    padding: 0;
  }

  .post {
    padding: 100px 62px 60px;
    min-height: calc(100svh - 266px);
  }

  /* ── CARD ── */
  .post__card {
    background-color: var(--color-brand-50);
    border: 1px solid var(--color-brand-500);
    border-radius: 12px;
    padding: 20px 20px 32px;
  }

  .post__question {
    font-family: var(--font-display);
    font-weight: 400;
    font-style: normal;
    font-size: 1.5rem;
    color: var(--color-brand-900);
    margin: 0 0 16px;
    line-height: 1.3;
  }

  .post__divider {
    width: 100%;
    height: 1px;
    background-color: var(--color-brand-900);
    opacity: 0.2;
    margin-bottom: 20px;
  }

  .post__body {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1.1rem;
    color: var(--color-brand-900);
    line-height: 1.7;
  }

  .post__body :global(p) {
    margin: 0 0 16px;
  }

  .post__body :global(p:last-child) {
    margin-bottom: 0;
  }

  .post__body :global(strong) {
    font-weight: 700;
  }

  /* ── LOWER ROW ── */
  .post__lower {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-top: 40px;
  }

  /* ── RELATED ── */
  .post__related {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .post__related-label {
    display: inline-block;
    background-color: var(--color-yellow-500);
    padding: 4px 12px;
    border-radius: 999px;
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1rem;
    color: var(--color-black);
    width: fit-content;
  }

  .post__related-list {
    list-style: none;
    margin: 0;
    padding: 0 0 0 4px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .post__related-link {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1rem;
    color: var(--color-brand-900);
    text-decoration: none;
    line-height: 1.6;
    transition: color 0.15s ease;
  }

  .post__related-link:hover {
    color: var(--color-brand-400);
  }

  /* ── CSS MAIL ENVELOPE ── */
  .post__mail {
    width: 110px;
    height: 78px;
    flex-shrink: 0;
    margin-top: 8px;
  }

  .post__mail-body {
    width: 100%;
    height: 100%;
    border: 2px solid var(--color-brand-400);
    border-radius: 2px;
    position: relative;
    overflow: hidden;
  }

  .post__mail-flap::before,
  .post__mail-flap::after {
    content: '';
    position: absolute;
    top: 0;
    width: 51%;
    height: 52%;
    border-bottom: 2px solid var(--color-brand-400);
  }

  .post__mail-flap::before {
    left: 0;
    transform-origin: top left;
    transform: rotate(32deg);
  }

  .post__mail-flap::after {
    right: 0;
    transform-origin: top right;
    transform: rotate(-32deg);
  }

  /* ── FOOTER ── */
  .blog-footer {
    background-color: var(--color-brand-100);
    background-image:
      linear-gradient(rgba(110, 57, 151, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(110, 57, 151, 0.08) 1px, transparent 1px);
    background-size: 40px 40px;
    height: 266px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    position: relative;
    overflow: hidden;
  }

  .blog-footer__heading {
    font-family: var(--font-display);
    font-weight: 500;
    font-style: italic;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    color: var(--color-brand-900);
    margin: 0;
    letter-spacing: -0.06em;
    line-height: 0.95;
    text-align: center;
  }

  .blog-footer__sub {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1rem;
    color: var(--color-brand-900);
    margin: 0;
    text-align: center;
  }

  /* ── MOBILE ── */
  @media (max-width: 768px) {
    .post {
      padding: 100px 16px 40px;
    }

    /* Keep lower as row: related links left, mail envelope right */
    .post__lower {
      gap: 16px;
      align-items: flex-start;
    }

    /* Show mail on mobile, sized to fit beside the related list */
    .post__mail {
      display: block;
      width: 90px;
      height: 64px;
      flex-shrink: 0;
      margin-top: 36px;
    }
  }
</style>
